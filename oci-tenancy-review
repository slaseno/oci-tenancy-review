    [[ -s "$compute_region_json" ]] || { echo "[]" > "${out_dir}/${slug}_limits.json"; merge_limits_json_to_csv "${out_dir}/${slug}_limits.json" "${out_dir}/${slug}_limits.csv"; return 0; }
    build_region_limit_prefixes "$region" "$prefixes_file" "$compute_region_json"
    [[ -s "$prefixes_file" ]] || { echo "[]" > "${out_dir}/${slug}_limits.json"; merge_limits_json_to_csv "${out_dir}/${slug}_limits.json" "${out_dir}/${slug}_limits.csv"; return 0; }
  fi

  oci_cli limits value list --compartment-id "$TENANCY_OCID" --service-name "$service_name" --all --region "$region" --output json > "$values_file"
  while IFS=$'\t' read -r limit_name scope_type ad_name limit_value; do
    [[ -n "$limit_name" ]] || continue
    # OCI object-storage limits can return REGION-scoped values in availability-domain with empty value.
    # Normalize to our CSV schema: availability-domain empty, limit-value populated.
    if [[ "$scope_type" != "AD" ]] && [[ -z "$limit_value" ]] && [[ "$ad_name" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
      limit_value="$ad_name"
      ad_name=""
    fi
    if [[ "$service_name" == "compute" ]] && ! limit_matches_prefixes "$limit_name" "$prefixes_file"; then
      continue
    fi
    local ra_json used_val="" avail_val=""
    if [[ "$scope_type" == "AD" && -n "$ad_name" && "$ad_name" != "null" ]]; then
      if ra_json="$(oci_cli limits resource-availability get --compartment-id "$TENANCY_OCID" --service-name "$service_name" --limit-name "$limit_name" --availability-domain "$ad_name" --region "$region" --output json 2>/dev/null)"; then
        used_val="$(echo "$ra_json" | jq -r '.data.used // .data.currentUsage // empty')"
        avail_val="$(echo "$ra_json" | jq -r '.data.available // .data.availableAmount // empty')"
      fi
    else
      if ra_json="$(oci_cli limits resource-availability get --compartment-id "$TENANCY_OCID" --service-name "$service_name" --limit-name "$limit_name" --region "$region" --output json 2>/dev/null)"; then
        used_val="$(echo "$ra_json" | jq -r '.data.used // .data.currentUsage // empty')"
        avail_val="$(echo "$ra_json" | jq -r '.data.available // .data.availableAmount // empty')"
      fi
    fi
    jq -cn --arg region "$region" --arg service "$service_name" --arg limit "$limit_name" --arg scope "$scope_type" --arg ad "$ad_name" --arg value "$limit_value" --arg used "$used_val" --arg avail "$avail_val" '{region: $region, serviceName: $service, limitName: $limit, scopeType: $scope, availabilityDomain: $ad, limitValue: $value, used: $used, available: $avail}' >> "$rows_jsonl"
  done < <(jq -r '.data[]? | [(.name // ""), (."scope-type" // .scopeType // ""), (."availability-domain" // .availabilityDomain // ""), (.value // "")] | @tsv' "$values_file")

  jq -s 'def to_num: if . == null or . == "" then null else (try (tonumber) catch null) end; def pct($u; $l): if $u == null or $l == null or $l == 0 then null else (($u / $l) * 100) end; map(. as $r | ($r.limitValue | to_num) as $limit | ($r.used | to_num) as $used | ($r.available | to_num) as $avail | (pct($used; $limit)) as $pct | {region: $r.region, serviceName: $r.serviceName, limitName: $r.limitName, scopeType: $r.scopeType, availabilityDomain: $r.availabilityDomain, limitValue: $limit, used: $used, available: $avail, usagePercent: $pct, id: ($r.region + ":" + $r.serviceName + ":" + ($r.scopeType // "") + ":" + ($r.availabilityDomain // "") + ":" + $r.limitName)}) | sort_by(-( .usagePercent // -1 ), .region, .serviceName, .limitName)' "$rows_jsonl" > "${out_dir}/${slug}_limits.json"
  merge_limits_json_to_csv "${out_dir}/${slug}_limits.json" "${out_dir}/${slug}_limits.csv"
  rm -f "$rows_jsonl" "$values_file" "$prefixes_file"
}

merge_limits_region_all_services() {
  local region="$1"
  local out_dir
  out_dir="report/limits/regions/${region}"
  local -a json_files
  local f
  json_files=()
  for f in "${out_dir}/compute_limits.json" "${out_dir}/block_storage_limits.json" "${out_dir}/object_storage_limits.json"; do
    [[ -s "$f" ]] && json_files+=("$f")
  done
  if [[ "${#json_files[@]}" -eq 0 ]]; then
    echo "[]" > "${out_dir}/service_limits.json"
  else
    jq -s '[.[][]] | sort_by(-( .usagePercent // -1 ), .region, .serviceName, .limitName)' "${json_files[@]}" > "${out_dir}/service_limits.json"
  fi
  merge_limits_json_to_csv "${out_dir}/service_limits.json" "${out_dir}/service_limits.csv"
}

build_limits_region() {
  local region="$1"
  local service_scope="${2:-all}"
  init_report_dirs
  require_tenancy
  [[ -n "$region" ]] || fatal "Region is required"
  case "$service_scope" in
    all|"")
      build_limits_region_service "$region" "compute"
      build_limits_region_service "$region" "block-storage"
      build_limits_region_service "$region" "object-storage"
      ;;
    compute|block-storage|object-storage)
      build_limits_region_service "$region" "$service_scope"
      ;;
    *)
      fatal "Invalid limits service scope: $service_scope"
      ;;
  esac
  merge_limits_region_all_services "$region"
  local total
  total="$(tail -n +2 "report/limits/regions/${region}/service_limits.csv" | wc -l | tr -d ' ')"
  verbose "Done. ${total} limits scoped ${service_scope:-all} in ${region}."
}

merge_limits_regions_by_service() {
  local service_name="$1"
  local slug
  local -a json_files
  local region f
  init_report_dirs
  ensure_target_regions
  slug="$(limit_service_slug "$service_name")"
  json_files=()
  collect_target_regions_array
  for region in "${TARGET_REGIONS[@]}"; do
    f="report/limits/regions/${region}/${slug}_limits.json"
    [[ -s "$f" ]] || fatal "Missing region limits artifact: $f"
    json_files+=("$f")
  done
  jq -s '[.[][]] | sort_by(-( .usagePercent // -1 ), .region, .serviceName, .limitName)' "${json_files[@]}" > "report/limits/${slug}_limits.json"
  merge_limits_json_to_csv "report/limits/${slug}_limits.json" "report/limits/${slug}_limits.csv"
}

merge_limits_regions() {
  init_report_dirs
  local -a json_files
  local f
  json_files=()
  for f in report/limits/compute_limits.json report/limits/block_storage_limits.json report/limits/object_storage_limits.json; do
    [[ -s "$f" ]] && json_files+=("$f")
  done
  if [[ "${#json_files[@]}" -eq 0 ]]; then
    echo "[]" > report/limits/service_limits.json
  else
    jq -s '[.[][]] | sort_by(-( .usagePercent // -1 ), .region, .serviceName, .limitName)' "${json_files[@]}" > report/limits/service_limits.json
  fi
  verbose "wrote 'report/limits/service_limits.json'"
  merge_limits_json_to_csv report/limits/service_limits.json report/limits/service_limits.csv
  verbose "wrote 'report/limits/service_limits.csv'"
  local total
  total="$(tail -n +2 report/limits/service_limits.csv | wc -l | tr -d ' ')"
  log "Done. ${total} limits."
}

build_compute_limits() {
  init_report_dirs
  require_tenancy
  ensure_target_regions
  [[ -s report/compute/compute_instances.json ]] || build_compute
  local region
  while IFS= read -r region; do
    [[ -n "$region" ]] || continue
    [[ -s "report/compute/regions/${region}/compute_instances.json" ]] || build_compute_region "$region"
    build_limits_region "$region" "compute"
  done < <(resolve_target_regions)
  merge_limits_regions_by_service "compute"
}

build_block_storage_limits() {
  init_report_dirs
  require_tenancy
  ensure_target_regions
  [[ -s report/storage/storage_inventory_enriched.json ]] || build_storage
  local region
  while IFS= read -r region; do
    [[ -n "$region" ]] || continue
    [[ -s "report/storage/regions/${region}/storage_inventory_enriched.json" ]] || build_storage_region "$region"
    build_limits_region "$region" "block-storage"
  done < <(resolve_target_regions)
  merge_limits_regions_by_service "block-storage"
}

build_object_storage_limits() {
  init_report_dirs
  require_tenancy
  ensure_target_regions
  [[ -s report/object-storage/buckets_inventory.json ]] || build_object_storage
  local region
  while IFS= read -r region; do
    [[ -n "$region" ]] || continue
    [[ -s "report/object-storage/regions/${region}/buckets_inventory.json" ]] || build_object_storage_region "$region"
    build_limits_region "$region" "object-storage"
  done < <(resolve_target_regions)
  merge_limits_regions_by_service "object-storage"
}

build_limits() {
  build_compute_limits
  build_block_storage_limits
  build_object_storage_limits
  merge_limits_regions
}

build_storage() {
  init_report_dirs
  require_tenancy
  ensure_compartments
  ensure_target_regions
  local region
  while IFS= read -r region; do
    [[ -n "$region" ]] || continue
    build_storage_region "$region"
  done < <(resolve_target_regions)
  merge_storage_regions
}

build_base_database_db_system_map() {
  local region="$1"
  local cid="$2"
  local db_system_ids_file="$3"
  local out_file="$4"
  local tmp_dir
  local jsonl_file
  local node_details_jsonl_file
  local db_system_id

  tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/oci-review-db-systems.XXXXXX")"
  jsonl_file="${tmp_dir}/db_systems.jsonl"
  node_details_jsonl_file="${tmp_dir}/db_node_details.jsonl"
  : > "$jsonl_file"
  : > "$node_details_jsonl_file"

  while IFS= read -r db_system_id; do
    [[ -n "$db_system_id" ]] || continue
    local db_system_file
    local db_nodes_file
    db_system_file="${tmp_dir}/${db_system_id}.json"
    db_nodes_file="${tmp_dir}/${db_system_id}_nodes.json"

    oci_cli db system get --db-system-id "$db_system_id" --region "$region" --output json > "$db_system_file"
    oci_cli db node list --compartment-id "$cid" --db-system-id "$db_system_id" --region "$region" --all --output json > "$db_nodes_file"

    : > "$node_details_jsonl_file"
    while IFS= read -r db_node_id; do
      [[ -n "$db_node_id" ]] || continue
      oci_cli db node get --db-node-id "$db_node_id" --region "$region" --output json \
        | jq -c '.data // .' >> "$node_details_jsonl_file"
    done < <(jq -r '.data[]? | (.id // "") | select(length > 0)' "$db_nodes_file")

    jq -cn --slurpfile dbs "$db_system_file" --slurpfile node_summaries "$db_nodes_file" --slurpfile node_details "$node_details_jsonl_file" '
      ($dbs[0].data // $dbs[0] // {}) as $s
      | ($node_summaries[0].data // []) as $summaryNodes
      | (if ($node_details | length) > 0 then $node_details else $summaryNodes end) as $n
      | ($n | map(."software-storage-size-in-gb" // .softwareStorageSizeInGB // empty)) as $softwareSizes
      | ($s."data-storage-size-in-gbs" // $s.dataStorageSizeInGBs // empty) as $dataStorageSize
      | ($s."reco-storage-size-in-gb" // $s.recoStorageSizeInGB // empty) as $recoStorageSize
      | (if ($softwareSizes | length) == 0 then empty else ($softwareSizes | add) end) as $softwareStorageTotal
      | {
          id: ($s.id // ""),
          value: {
            dbSystemDisplayName: ($s."display-name" // $s.displayName // ""),
            dbSystemShape: ($s.shape // ""),
            dbSystemAvailabilityDomain: ($s."availability-domain" // $s.availabilityDomain // ""),
            dbSystemHostname: ($s.hostname // ""),
            dbSystemDomain: ($s.domain // ""),
            dbSystemCpuCoreCount: ($s."cpu-core-count" // $s.cpuCoreCount // ""),
            dbSystemComputeModel: ($s."compute-model" // $s.computeModel // ""),
            dbSystemComputeCount: ($s."compute-count" // $s.computeCount // ""),
            dbSystemMemorySizeInGbs: ($s."memory-size-in-gbs" // $s.memorySizeInGBs // ""),
            dbSystemNodeCount: ($s."node-count" // $s.nodeCount // ""),
            dbSystemStorageVolumePerformanceMode: ($s."storage-volume-performance-mode" // $s.storageVolumePerformanceMode // ""),
            dbSystemDataStoragePercentage: ($s."data-storage-percentage" // $s.dataStoragePercentage // ""),
            dbSystemDataStorageSizeInGbs: ($dataStorageSize // ""),
            dbSystemRecoStorageSizeInGb: ($recoStorageSize // ""),
            dbSystemSoftwareStorageSizeInGbTotal: (if ($softwareSizes | length) == 0 then "" else ($softwareSizes | add) end),
            dbSystemTotalStorageSizeInGbs: (
              [($dataStorageSize // empty), ($recoStorageSize // empty), ($softwareStorageTotal // empty)]
              | if length == 0 then "" else add end
            ),
            dbSystemLicenseModel: ($s."license-model" // $s.licenseModel // ""),
            dbSystemDiskRedundancy: ($s."disk-redundancy" // $s.diskRedundancy // ""),
            dbSystemSparseDiskgroup: (
              if ($s | has("sparse-diskgroup")) then $s."sparse-diskgroup"
              elif ($s | has("sparseDiskgroup")) then $s.sparseDiskgroup
              else ""
              end
            ),
            dbSystemKmsKeyId: ($s."kms-key-id" // $s.kmsKeyId // ""),
            dbSystemLifecycleState: ($s."lifecycle-state" // $s.lifecycleState // ""),
            dbSystemLifecycleDetails: ($s."lifecycle-details" // $s.lifecycleDetails // ""),
            dbSystemFreeformTagCount: (($s."freeform-tags" // $s.freeformTags // {}) | keys | length),
            dbSystemDefinedTagNamespaceCount: (($s."defined-tags" // $s.definedTags // {}) | keys | length),
            dbSystemTimeCreated: ($s."time-created" // $s.timeCreated // "")
          }
        }
    ' >> "$jsonl_file"
  done < "$db_system_ids_file"

  if [[ -s "$jsonl_file" ]]; then
    jq -s 'map(select(.id != "")) | map({key: .id, value: .value}) | from_entries' "$jsonl_file" > "$out_file"
  else
    echo "{}" > "$out_file"
  fi

  rm -rf "$tmp_dir"
}

build_base_database_backup_size_map() {
  local region="$1"
  local db_json_file="$2"
  local out_file="$3"
  local tmp_dir
  local jsonl_file
  local db_id

  tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/oci-review-db-backups.XXXXXX")"
  jsonl_file="${tmp_dir}/db_backups.jsonl"
  : > "$jsonl_file"

  while IFS= read -r db_id; do
    [[ -n "$db_id" ]] || continue
    local backup_file
    backup_file="${tmp_dir}/${db_id}.json"
    oci_cli db backup list --database-id "$db_id" --region "$region" --all --output json > "$backup_file"

    jq -cn --arg id "$db_id" --slurpfile backups "$backup_file" '
      ($backups[0].data // []) as $b
      | {
          id: $id,
          value: {
            databaseBackupsTotalSizeInGbs: (
              $b
              | map(."database-size-in-gbs" // .databaseSizeInGBs // empty)
              | if length == 0 then 0 else add end
            )
          }
        }
    ' >> "$jsonl_file"
  done < <(jq -r '.data[]? | (.id // "") | select(length > 0)' "$db_json_file")

  if [[ -s "$jsonl_file" ]]; then
    jq -s 'map(select(.id != "")) | map({key: .id, value: .value}) | from_entries' "$jsonl_file" > "$out_file"
  else
    echo "{}" > "$out_file"
  fi

  rm -rf "$tmp_dir"
}

build_base_database_compartment_region() {
  local region="$1"
  local cid="$2"
  local out_file="$3"
  local cpath
  local cpath_file
  local db_json_file
  local db_system_ids_file
  local db_system_map_file
  local db_backup_map_file
  cpath="$(get_compartment_path "$cid")"
  cpath_file="$(write_compartment_path_file "$cpath")"
  db_json_file="$(mktemp "${TMPDIR:-/tmp}/oci-review-base-db.XXXXXX")"
  db_system_ids_file="$(mktemp "${TMPDIR:-/tmp}/oci-review-base-db-systems.XXXXXX")"
  db_system_map_file="$(mktemp "${TMPDIR:-/tmp}/oci-review-base-db-system-map.XXXXXX")"
  db_backup_map_file="$(mktemp "${TMPDIR:-/tmp}/oci-review-base-db-backup-map.XXXXXX")"

  oci_cli db database list --compartment-id "$cid" --region "$region" --output json > "$db_json_file"
  jq -r '.data[]? | (."db-system-id" // .dbSystemId // "") | select(length > 0)' "$db_json_file" | sort -u > "$db_system_ids_file"
  build_base_database_db_system_map "$region" "$cid" "$db_system_ids_file" "$db_system_map_file"
