        .data[]?
        | (."db-backup-config" // .dbBackupConfig // {}) as $b
        | ($dbs[(."db-system-id" // .dbSystemId // "")] // {}) as $s
        | ($backupSizes[(.id // "")] // {}) as $backup
        | {
          compartmentId: $cid,
          compartmentPath: $cpath,
          region: $region,
          dbName: (."db-name" // .dbName // ."display-name" // ""),
          dbUniqueName: (."db-unique-name" // .dbUniqueName // ""),
          dbWorkload: (."db-workload" // .dbWorkload // ""),
          dbVersion: (."db-version" // .dbVersion // ""),
          dbSystemId: (."db-system-id" // .dbSystemId // ""),
          dbSystemDisplayName: ($s.dbSystemDisplayName // ""),
          dbSystemShape: ($s.dbSystemShape // ""),
          dbSystemAvailabilityDomain: ($s.dbSystemAvailabilityDomain // ""),
          dbSystemHostname: ($s.dbSystemHostname // ""),
          dbSystemDomain: ($s.dbSystemDomain // ""),
          dbSystemCpuCoreCount: ($s.dbSystemCpuCoreCount // ""),
          dbSystemComputeModel: ($s.dbSystemComputeModel // ""),
          dbSystemComputeCount: ($s.dbSystemComputeCount // ""),
          dbSystemMemorySizeInGbs: ($s.dbSystemMemorySizeInGbs // ""),
          dbSystemNodeCount: ($s.dbSystemNodeCount // ""),
          dbSystemStorageVolumePerformanceMode: ($s.dbSystemStorageVolumePerformanceMode // ""),
          dbSystemDataStoragePercentage: ($s.dbSystemDataStoragePercentage // ""),
          dbSystemDataStorageSizeInGbs: ($s.dbSystemDataStorageSizeInGbs // ""),
          dbSystemRecoStorageSizeInGb: ($s.dbSystemRecoStorageSizeInGb // ""),
          dbSystemSoftwareStorageSizeInGbTotal: ($s.dbSystemSoftwareStorageSizeInGbTotal // ""),
          dbSystemTotalStorageSizeInGbs: ($s.dbSystemTotalStorageSizeInGbs // ""),
          dbSystemLicenseModel: ($s.dbSystemLicenseModel // ""),
          dbSystemDiskRedundancy: ($s.dbSystemDiskRedundancy // ""),
          dbSystemSparseDiskgroup: (if ($s | has("dbSystemSparseDiskgroup")) then $s.dbSystemSparseDiskgroup else "" end),
          dbSystemKmsKeyId: ($s.dbSystemKmsKeyId // ""),
          dbSystemLifecycleState: ($s.dbSystemLifecycleState // ""),
          dbSystemLifecycleDetails: ($s.dbSystemLifecycleDetails // ""),
          dbSystemFreeformTagCount: ($s.dbSystemFreeformTagCount // ""),
          dbSystemDefinedTagNamespaceCount: ($s.dbSystemDefinedTagNamespaceCount // ""),
          dbSystemTimeCreated: ($s.dbSystemTimeCreated // ""),
          dbHomeId: (."db-home-id" // .dbHomeId // ""),
          vmClusterId: (."vm-cluster-id" // .vmClusterId // ""),
          cdbName: (."cdb-name" // .cdbName // ""),
          pdbName: (."pdb-name" // .pdbName // ""),
          lifecycleState: (."lifecycle-state" // .lifecycleState // ""),
          lifecycleDetails: (."lifecycle-details" // .lifecycleDetails // ""),
          characterSet: (."character-set" // .characterSet // ""),
          ncharacterSet: (."ncharacter-set" // .ncharacterSet // ""),
          isCdb: (."is-cdb" // .isCdb // false),
          kmsKeyId: (."kms-key-id" // .kmsKeyId // ""),
          kmsKeyVersionId: (."kms-key-version-id" // .kmsKeyVersionId // ""),
          keyStoreId: (."key-store-id" // .keyStoreId // ""),
          keyStoreWalletName: (."key-store-wallet-name" // .keyStoreWalletName // ""),
          vaultId: (."vault-id" // .vaultId // ""),
          databaseSoftwareImageId: (."database-software-image-id" // .databaseSoftwareImageId // ""),
          sidPrefix: (."sid-prefix" // .sidPrefix // ""),
          autoBackupEnabled: ($b."auto-backup-enabled" // $b.autoBackupEnabled // false),
          backupRecoveryWindowInDays: ($b."recovery-window-in-days" // $b.recoveryWindowInDays // ""),
          backupDestinationType: ($b."backup-destination-type" // $b.backupDestinationType // ""),
          autoFullBackupDay: ($b."auto-full-backup-day" // $b.autoFullBackupDay // ""),
          lastBackupTimestamp: (."last-backup-timestamp" // .lastBackupTimestamp // ""),
          lastFailedBackupTimestamp: (."last-failed-backup-timestamp" // .lastFailedBackupTimestamp // ""),
          lastBackupDurationInSeconds: (."last-backup-duration-in-seconds" // .lastBackupDurationInSeconds // ""),
          databaseBackupsTotalSizeInGbs: ($backup.databaseBackupsTotalSizeInGbs // 0),
          freeformTagCount: ((."freeform-tags" // .freeformTags // {}) | keys | length),
          definedTagNamespaceCount: ((."defined-tags" // .definedTags // {}) | keys | length),
          timeCreated: (."time-created" // .timeCreated // ""),
          id: (.id // "")
        }
      ' "$db_json_file" > "$out_file"
  rm -f "$cpath_file" "$db_json_file" "$db_system_ids_file" "$db_system_map_file" "$db_backup_map_file"
}

