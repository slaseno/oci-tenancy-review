#!/usr/bin/env bash

set -Eeuo pipefail

VERSION="0.1.0"
DEBUG_MODE="false"
COLORS_ENABLED="${COLORS_ENABLED:=$( (command -v tput > /dev/null 2>&1 && [[ $(tput -T"${TERM:-dumb}" colors 2>/dev/null || echo 0) -ge 8 ]] && echo "true") || echo "false")}"
COLOR_RED=$([ "$COLORS_ENABLED" == "true" ] && printf "\033[0;31m" || printf "")
COLOR_GREEN=$([ "$COLORS_ENABLED" == "true" ] && printf "\033[0;32m" || printf "")
COLOR_YELLOW=$([ "$COLORS_ENABLED" == "true" ] && printf "\033[0;33m" || printf "")
COLOR_GRAY=$([ "$COLORS_ENABLED" == "true" ] && printf "\033[0;90m" || printf "")
COLOR_END=$([ "$COLORS_ENABLED" == "true" ] && printf "\033[0m" || printf "")

usage() {
  cat <<USAGE
Usage: ./oci-tenancy-review <command> [-d|--debug]
Version: ${VERSION}

Commands:
  regions        Export subscribed region names to report/regions.txt
  compartments   Build tenancy compartment map at report/compartments.csv
  policies       Export tenancy policy statements to report/policies/policy_statements.csv
  compute        Export compute inventory to report/compute/compute_instances.csv
  block-storage        Export block + boot volume inventory to report/storage/storage_inventory.csv
  limits         Export compute + block-storage limits posture to report/limits/service_limits.csv
  all            Run compartments + policies + compute + block-storage + limits
  help           Show this help

Required environment:
  TENANCY_OCID   Tenancy OCID (ocid1.tenancy...)
Optional environment:
  OCI_REVIEW_REGIONS  Comma-separated region list for compute discovery (for example: eu-frankfurt-1,eu-zurich-1).
                      If unset, all subscribed regions are used.
  BLACKLISTED_REGIONS Comma-separated region blacklist for compute discovery.
                      Default: eu-kragujevac-1

Examples:
  export TENANCY_OCID="ocid1.tenancy.oc1...."
  ./oci-tenancy-review regions
  ./oci-tenancy-review compartments
  ./oci-tenancy-review policies
  ./oci-tenancy-review compute
  ./oci-tenancy-review block-storage
  ./oci-tenancy-review limits
  ./oci-tenancy-review compute --debug
  ./oci-tenancy-review all
USAGE
}

log() {
  local msg="$1"
  printf '%b[I] %s: %s%b\n' "$COLOR_GREEN" "${FUNCNAME[1]}" "$msg" "$COLOR_END" >&2
}

verbose() {
  local msg="$1"
  printf '%b[V] %s: %s%b\n' "$COLOR_GRAY" "${FUNCNAME[1]}" "$msg" "$COLOR_END" >&2
}

warn() {
  local msg="$1"
  printf '%b[W] %s: %s%b\n' "$COLOR_YELLOW" "${FUNCNAME[1]}" "$msg" "$COLOR_END" >&2
}

err() {
  local msg="$1"
  printf '%b[E] %s: %s%b\n' "$COLOR_RED" "${FUNCNAME[1]}" "$msg" "$COLOR_END" >&2
}

fatal() {
  local msg="$1"
  printf '%b[F] %s: %s%b\n' "$COLOR_RED" "${FUNCNAME[1]}" "$msg" "$COLOR_END" >&2
  exit 1
}


progress_dot() {
  [[ "$DEBUG_MODE" == "true" ]] || printf '.' >&2
}

progress_prefix() {
  local message="$1"
  [[ "$DEBUG_MODE" == "true" ]] || printf '%b[I] %s %b' "$COLOR_GREEN" "$message" "$COLOR_END" >&2
}

progress_newline() {
  if [[ "$DEBUG_MODE" == "true" ]]; then
    return 0
  fi
  printf '\n' >&2
  return 0
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || fatal "Missing required command: $1"
}


init_report_dirs() {
  mkdir -p report report/compute report/policies report/limits report/storage
}

require_tenancy() {
  [[ -n "${TENANCY_OCID:-}" ]] || fatal "TENANCY_OCID is required"
}

get_review_regions() {
  if [[ -z "${OCI_REVIEW_REGIONS:-}" ]]; then
    return 0
  fi

  echo "$OCI_REVIEW_REGIONS" \
    | tr ',' '\n' \
    | awk '{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0); if (length($0) > 0) print $0}'
}

get_all_subscribed_regions() {
  oci iam region-subscription list \
    --tenancy-id "$TENANCY_OCID" \
    --all \
    --output json \
    | jq -r '.data[]?."region-name"'
}

get_blacklisted_regions() {
  if [[ -z "${BLACKLISTED_REGIONS+x}" ]]; then
    echo "eu-kragujevac-1"
    return 0
  fi

  echo "${BLACKLISTED_REGIONS}" \
    | tr ',' '\n' \
    | awk '{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0); if (length($0) > 0) print $0}'
}

is_blacklisted_region() {
  local region="$1"
  local blocked
  while IFS= read -r blocked; do
    [[ -n "$blocked" ]] || continue
    if [[ "$region" == "$blocked" ]]; then
      return 0
    fi
  done < <(get_blacklisted_regions)
  return 1
}

is_region_reachable() {
  local region="$1"
  oci iam availability-domain list \
    --compartment-id "$TENANCY_OCID" \
    --region "$region" \
    --all \
    --output json >/dev/null
}

filter_reachable_regions() {
  progress_prefix "filter_reachable_regions processing"
  local region
  local had_iterations="false"
  for region in "$@"; do
    progress_dot
    had_iterations="true"
    [[ -n "$region" ]] || continue
    if is_blacklisted_region "$region"; then
      progress_newline
      warn "Skipping blacklisted region: $region"
      continue
    fi
    if is_region_reachable "$region"; then
      echo "$region"
    else
      progress_newline
      warn "Skipping unreachable region: $region"
    fi
  done
  if [[ "$had_iterations" == "true" ]]; then
    progress_newline
  fi
}

resolve_target_regions() {
  local -a requested_regions
  local -a regions
  requested_regions=()
  if [[ -n "${OCI_REVIEW_REGIONS:-}" ]]; then
    while IFS= read -r region; do
      [[ -n "$region" ]] && requested_regions+=("$region")
    done < <(get_review_regions || true)
  else
    while IFS= read -r region; do
      [[ -n "$region" ]] && requested_regions+=("$region")
    done < <(get_all_subscribed_regions || true)
  fi

  regions=()
  if [[ "${#requested_regions[@]}" -gt 0 ]]; then
    while IFS= read -r region; do
      [[ -n "$region" ]] && regions+=("$region")
    done < <(filter_reachable_regions "${requested_regions[@]}")
  fi

  [[ "${#regions[@]}" -gt 0 ]] || fatal "No reachable regions from requested region set"
  log "regions to inspect: $(printf '%s ' "${regions[@]}" | sed 's/[[:space:]]*$//')"
  printf '%s\n' "${regions[@]}"
}

build_regions() {
  init_report_dirs
  require_tenancy

  get_all_subscribed_regions | sort -u > report/regions.txt
  verbose "wrote 'report/regions.txt'"
  cat report/regions.txt
}

build_compartments() {
  init_report_dirs
  require_tenancy

  oci iam compartment list \
    --compartment-id "$TENANCY_OCID" \
    --compartment-id-in-subtree true \
    --access-level ANY \
    --include-root \
    --all \
    --output json > report/compartments.json

  {
    echo "compartment-id,compartment-path"
    jq -r --arg tenancy "$TENANCY_OCID" '
    .data as $d
    | ($d | map({key: .id, value: .}) | from_entries) as $m
    | def full_path($id):
        if $id == $tenancy then
          ""
        else
          (full_path($m[$id]."compartment-id")) as $p
          | if $p == "" then $m[$id].name else ($p + "." + $m[$id].name) end
        end;
      [ $d[] | {id: .id, path: (if .id == $tenancy then "root" else full_path(.id) end)} ]
    | sort_by(if .path == "root" then "" else .path end)
    | .[]
    | .id + "," + .path
  ' report/compartments.json
  } > report/compartments.csv
  verbose "wrote 'report/compartments.json'"
  verbose "wrote 'report/compartments.csv'"

  total_compartments="$(tail -n +2 report/compartments.csv | wc -l | tr -d ' ')"
  log "${total_compartments} total compartments."
}

ensure_compartments() {
  [[ -s report/compartments.csv ]] || build_compartments
}

get_compartment_path() {
  local cid="$1"
  awk -F',' -v cid="$cid" 'NR>1 && $1==cid {sub(/^[^,]*,/, "", $0); print $0; exit}' report/compartments.csv
}

build_region_limit_prefixes() {
  local region="$1"
  local out_file="$2"

  > "$out_file"
  jq -r --arg region "$region" '.[] | select(.region == $region) | .shape // empty' report/compute/compute_instances.json \
    | while read -r shape; do
        local shape_lc
        shape_lc="$(echo "$shape" | tr '[:upper:]' '[:lower:]')"

        if [[ "$shape_lc" =~ ^(vm|bm)\.standard\.([a-z0-9]+)\.flex$ ]]; then
          local fam
          fam="${BASH_REMATCH[2]}"
          echo "standard-${fam}-" >> "$out_file"
          echo "vm-standard-${fam}-" >> "$out_file"
        fi

        if [[ "$shape_lc" =~ ^(vm|bm)\.standard([0-9]+)\..*$ ]]; then
          local gen
          gen="${BASH_REMATCH[2]}"
          echo "standard${gen}-" >> "$out_file"
          echo "vm-standard${gen}-" >> "$out_file"
        fi
      done

  sort -u "$out_file" -o "$out_file"
}

limit_matches_prefixes() {
  local limit_name="$1"
  local prefixes_file="$2"
  local p
  while IFS= read -r p; do
    [[ -n "$p" ]] || continue
    if [[ "$limit_name" == "$p"* ]]; then
      return 0
    fi
  done < "$prefixes_file"
  return 1
}

search() {
  local query_text="$1"
  local out_file="$2"
  local resource_count=0
  shift 2
  local regions=("$@")
  if [[ "${#regions[@]}" -eq 0 ]]; then
    regions=("")
  fi
  local tmp_dir
  tmp_dir="$(dirname "$out_file")"
  local resp_file="${tmp_dir}/.search_response.json"
  local extracted_file="${tmp_dir}/.search_compartments.tmp"
  local ids_file="${out_file}.ids"

  > "$ids_file"
  local region page
  for region in "${regions[@]}"; do
    page=""
    progress_prefix "search '${query_text}' ${region:-default-region} processing"
    local had_iterations="false"
    while true; do
      progress_dot
      had_iterations="true"
      if [[ -n "$region" && -n "$page" ]]; then
        oci search resource structured-search \
          --query-text "$query_text" \
          --limit 1000 \
          --page "$page" \
          --region "$region" \
          --output json > "$resp_file"
      elif [[ -n "$region" ]]; then
        oci search resource structured-search \
          --query-text "$query_text" \
          --limit 1000 \
          --region "$region" \
          --output json > "$resp_file"
      elif [[ -n "$page" ]]; then
        oci search resource structured-search \
          --query-text "$query_text" \
          --limit 1000 \
          --page "$page" \
          --output json > "$resp_file"
      else
        oci search resource structured-search \
          --query-text "$query_text" \
          --limit 1000 \
          --output json > "$resp_file"
      fi

      jq -e '.' "$resp_file" >/dev/null 2>&1 || \
        fatal "Search query returned non-JSON output for: $query_text"

      jq -r '
        if (.data | type) == "array" then
          .data[]
        elif (.data | type) == "object" and ((.data.items | type) == "array") then
          .data.items[]
        elif (.items | type) == "array" then
          .items[]
        else
          empty
        end
        | (."compartment-id" // .compartmentId // .compartment_id // empty)
      ' "$resp_file" > "$extracted_file"

      resource_count=$((resource_count + $(wc -l < "$extracted_file")))
      cat "$extracted_file" >> "$ids_file"

      page="$(jq -r '."opc-next-page" // empty' "$resp_file")"
      [[ -z "$page" ]] && break
    done
    progress_newline
  done

  sort -u "$ids_file" -o "$ids_file"
  rm -f "$resp_file" "$extracted_file"

  {
    echo "compartment-id,compartment-path"
    while read -r cid; do
      [[ -n "$cid" ]] || continue
      cpath="$(get_compartment_path "$cid")"
      printf '%s,%s\n' "$cid" "$cpath"
    done < "$ids_file"
  } > "$out_file"
  verbose "wrote '$out_file'"

  local target_compartments
  target_compartments="$(tail -n +2 "$out_file" | wc -l | tr -d ' ')"
  log "search '${query_text}' returned ${resource_count} resources in ${target_compartments} compartments (regions=${regions})."

  rm -f "$ids_file"
}

build_policies() {
  init_report_dirs
  require_tenancy
  ensure_compartments

  search \
    "query policy resources" \
    "report/policies/policy_target_compartments.csv"

  > report/policies/policies_all_compartments.jsonl
  progress_prefix "build_policies processing"
  local had_policy_iterations="false"
  while IFS=',' read -r cid _; do
    [[ "$cid" == "compartment-id" ]] && continue
    [[ -n "$cid" ]] || continue
    progress_dot
    had_policy_iterations="true"
    cpath="$(get_compartment_path "$cid")"
    oci iam policy list -c "$cid" --all --output json \
      | jq -c --arg cid "$cid" --arg cpath "$cpath" '
          .data[]? | {
            compartmentId: $cid,
            compartmentPath: $cpath,
            name: .name,
            id: .id,
            timeCreated: ."time-created",
            definedTags: ."defined-tags",
            statements: .statements
          }
        ' >> report/policies/policies_all_compartments.jsonl
  done < report/policies/policy_target_compartments.csv
  progress_newline

  jq -s '.' report/policies/policies_all_compartments.jsonl > report/policies/policies_all_compartments.json
  verbose "wrote 'report/policies/policies_all_compartments.json'"

  jq -r '
    ["compartment-id","compartment-name","policy-name","created-by","time-created","the actual statement","id"],
    (.[] as $p | ($p.statements // [])[] |
      [$p.compartmentId, $p.compartmentPath, $p.name, ($p.definedTags["Oracle-Tags"]["CreatedBy"] // ""), $p.timeCreated, ., $p.id]
    ) | @csv
  ' report/policies/policies_all_compartments.json > report/policies/policy_statements.csv
  verbose "wrote 'report/policies/policy_statements.csv'"
}

build_compute() {
  init_report_dirs
  require_tenancy
  ensure_compartments
  local -a regions
  regions=()
  while IFS= read -r region; do
    [[ -n "$region" ]] && regions+=("$region")
  done < <(resolve_target_regions)

  > report/compute/compute_instances.jsonl
  local region
  for region in "${regions[@]}"; do
    local region_target_file
    region_target_file="report/compute/compute_target_compartments_${region}.csv"

    search \
      "query instance resources" \
      "$region_target_file" \
      "$region"

    progress_prefix "build_compute processing ${region}"
    local had_compute_iterations="false"
    while IFS=',' read -r cid _; do
      [[ "$cid" == "compartment-id" ]] && continue
      [[ -n "$cid" ]] || continue
      progress_dot
      had_compute_iterations="true"
      cpath="$(get_compartment_path "$cid")"
      oci compute instance list --compartment-id "$cid" --all --region "$region" --output json \
        | jq -c --arg cid "$cid" --arg cpath "$cpath" '
            .data[]? | {
              compartmentId: $cid,
              compartmentPath: $cpath,
              region: .region,
              instanceId: .id,
              instanceName: ."display-name",
              shape: .shape,
              ocpus: ."shape-config".ocpus,
              memoryInGBs: ."shape-config"."memory-in-gbs",
              baselineOcpuUtilization: ."shape-config"."baseline-ocpu-utilization",
              lifecycleState: ."lifecycle-state",
              availabilityDomain: ."availability-domain",
              faultDomain: ."fault-domain",
              imageId: ."image-id",
              launchMode: ."launch-mode",
              sourceType: ."source-details"."source-type",
              capacityReservationId: ."capacity-reservation-id",
              dedicatedVmHostId: ."dedicated-vm-host-id",
              preemptibleActionType: ."preemptible-instance-config"."preemption-action"."type",
              availabilityRecoveryAction: ."availability-config"."recovery-action",
              legacyImdsEndpointsDisabled: ."instance-options"."are-legacy-imds-endpoints-disabled",
              networkType: ."launch-options"."network-type",
              consistentVolumeNamingEnabled: ."launch-options"."is-consistent-volume-naming-enabled",
              monitoringDisabled: ."agent-config"."is-monitoring-disabled",
              managementDisabled: ."agent-config"."is-management-disabled",
              liveMigrationPreferred: ."is-live-migration-preferred",
              pvEncryptionInTransitEnabled: ."is-pv-encryption-in-transit-enabled",
              metadataKeyCount: ((.metadata // {}) | keys | length),
              freeformTagCount: ((."freeform-tags" // {}) | keys | length),
              definedTagNamespaceCount: ((."defined-tags" // {}) | keys | length),
              timeCreated: ."time-created"
            }
          ' >> report/compute/compute_instances.jsonl
    done < "$region_target_file"
    progress_newline
  done

  jq -s '.' report/compute/compute_instances.jsonl > report/compute/compute_instances.json
  verbose "wrote 'report/compute/compute_instances.json'"

  jq -r '
    ["compartment-path","region","instance-name","shape","ocpus","memory-in-gbs","baseline-ocpu-utilization","lifecycle-state","availability-domain","fault-domain","image-id","launch-mode","source-type","capacity-reservation-id","dedicated-vm-host-id","preemptible-action-type","availability-recovery-action","legacy-imds-endpoints-disabled","network-type","consistent-volume-naming-enabled","monitoring-disabled","management-disabled","live-migration-preferred","pv-encryption-in-transit-enabled","metadata-key-count","freeform-tag-count","defined-tag-namespace-count","time-created","instance-id"],
    (.[] | [.compartmentPath, .region, .instanceName, .shape, .ocpus, .memoryInGBs, .baselineOcpuUtilization, .lifecycleState, .availabilityDomain, .faultDomain, .imageId, .launchMode, .sourceType, .capacityReservationId, .dedicatedVmHostId, .preemptibleActionType, .availabilityRecoveryAction, .legacyImdsEndpointsDisabled, .networkType, .consistentVolumeNamingEnabled, .monitoringDisabled, .managementDisabled, .liveMigrationPreferred, .pvEncryptionInTransitEnabled, .metadataKeyCount, .freeformTagCount, .definedTagNamespaceCount, .timeCreated, .instanceId]) | @csv
  ' report/compute/compute_instances.json > report/compute/compute_instances.csv
  verbose "wrote 'report/compute/compute_instances.csv'"

  jq -r '
    ["shape","count"],
    (group_by(.shape) | map([.[0].shape, (length|tostring)]) | sort_by(.[1] | tonumber) | reverse | .[]) | @csv
  ' report/compute/compute_instances.json > report/compute/compute_shapes_summary.csv
  verbose "wrote 'report/compute/compute_shapes_summary.csv'"
}

ensure_compute_inventory() {
  [[ -s report/compute/compute_instances.json ]] || build_compute
}

ensure_storage_inventory() {
  [[ -s report/storage/storage_inventory_enriched.json ]] || build_storage
}

build_limits() {
  init_report_dirs
  require_tenancy
  ensure_compute_inventory
  ensure_storage_inventory

  local -a regions
  regions=()
  while IFS= read -r region; do
    [[ -n "$region" ]] && regions+=("$region")
  done < <(
    {
      jq -r '.[].region // empty' report/compute/compute_instances.json
      jq -r '.[] | select(.kind=="block-volume") | .region // empty' report/storage/storage_inventory_enriched.json
    } | sort -u
  )

  if [[ "${#regions[@]}" -eq 0 ]]; then
    echo "[]" > report/limits/service_limits.json
    jq -n -r '
      [
        "region",
        "service-name",
        "limit-name",
        "scope-type",
        "availability-domain",
        "limit-value",
        "used",
        "available",
        "usage-percent"
      ] | @csv
    ' > report/limits/service_limits.csv
    verbose "wrote 'report/limits/service_limits.json'"
    verbose "wrote 'report/limits/service_limits.csv'"
    return 0
  fi

  > report/limits/limits_rows.jsonl
  local region
  for region in "${regions[@]}"; do
    local service_name
    for service_name in compute block-storage; do
      local values_file
      values_file="report/limits/.values_${region}_${service_name}.json"
      local prefixes_file
      prefixes_file="report/limits/.prefixes_${region}.txt"

      if [[ "$service_name" == "compute" ]]; then
        build_region_limit_prefixes "$region" "$prefixes_file"
        if [[ ! -s "$prefixes_file" ]]; then
          rm -f "$values_file" "$prefixes_file"
          continue
        fi
      fi

      progress_prefix "build_limits ${region}/${service_name}"
      local had_limit_iterations="false"

      oci limits value list \
        --compartment-id "$TENANCY_OCID" \
        --service-name "$service_name" \
        --all \
        --region "$region" \
        --output json > "$values_file"

      while IFS=$'\t' read -r limit_name scope_type ad_name limit_value; do
        [[ -n "$limit_name" ]] || continue
        if [[ "$service_name" == "compute" ]]; then
          if ! limit_matches_prefixes "$limit_name" "$prefixes_file"; then
            continue
          fi
        fi
        progress_dot
        had_limit_iterations="true"

        local ra_json
        local used_val=""
        local avail_val=""

        if [[ "$scope_type" == "AD" && -n "$ad_name" && "$ad_name" != "null" ]]; then
          if ra_json="$(oci limits resource-availability get \
            --compartment-id "$TENANCY_OCID" \
            --service-name "$service_name" \
            --limit-name "$limit_name" \
            --availability-domain "$ad_name" \
            --region "$region" \
            --output json 2>/dev/null)"; then
            used_val="$(echo "$ra_json" | jq -r '.data.used // .data.currentUsage // empty')"
            avail_val="$(echo "$ra_json" | jq -r '.data.available // .data.availableAmount // empty')"
          fi
        else
          if ra_json="$(oci limits resource-availability get \
            --compartment-id "$TENANCY_OCID" \
            --service-name "$service_name" \
            --limit-name "$limit_name" \
            --region "$region" \
            --output json 2>/dev/null)"; then
            used_val="$(echo "$ra_json" | jq -r '.data.used // .data.currentUsage // empty')"
            avail_val="$(echo "$ra_json" | jq -r '.data.available // .data.availableAmount // empty')"
          fi
        fi

        jq -cn \
          --arg region "$region" \
          --arg service "$service_name" \
          --arg limit "$limit_name" \
          --arg scope "$scope_type" \
          --arg ad "$ad_name" \
          --arg value "$limit_value" \
          --arg used "$used_val" \
          --arg avail "$avail_val" '
          {
            region: $region,
            serviceName: $service,
            limitName: $limit,
            scopeType: $scope,
            availabilityDomain: $ad,
            limitValue: $value,
            used: $used,
            available: $avail
          }
        ' >> report/limits/limits_rows.jsonl
      done < <(
        jq -r '
          .data[]?
          | [
              (.name // ""),
              (."scope-type" // .scopeType // ""),
              (."availability-domain" // .availabilityDomain // ""),
              (.value // "")
            ]
          | @tsv
        ' "$values_file"
      )
      progress_newline
      [[ "$had_limit_iterations" == "true" ]] || true
      rm -f "$values_file" "$prefixes_file"
    done
  done

  jq -s '
    def to_num:
      if . == null or . == "" then null
      else (try (tonumber) catch null) end;
    def pct($u; $l):
      if $u == null or $l == null or $l == 0 then null
      else (($u / $l) * 100) end;
    map(
      . as $r
      | ($r.limitValue | to_num) as $limit
      | ($r.used | to_num) as $used
      | ($r.available | to_num) as $avail
      | (pct($used; $limit)) as $pct
      | {
          region: $r.region,
          serviceName: $r.serviceName,
          limitName: $r.limitName,
          scopeType: $r.scopeType,
          availabilityDomain: $r.availabilityDomain,
          limitValue: $limit,
          used: $used,
          available: $avail,
          usagePercent: $pct
        }
    )
    | sort_by(-( .usagePercent // -1 ), .region, .serviceName, .limitName)
  ' report/limits/limits_rows.jsonl > report/limits/service_limits.json
  verbose "wrote 'report/limits/service_limits.json'"

  jq -r '
    [
      "region",
      "service-name",
      "limit-name",
      "scope-type",
      "availability-domain",
      "limit-value",
      "used",
      "available",
      "usage-percent"
    ],
    (
      .[] |
      [
        .region,
        .serviceName,
        .limitName,
        .scopeType,
        .availabilityDomain,
        .limitValue,
        .used,
        .available,
        .usagePercent
      ]
    ) | @csv
  ' report/limits/service_limits.json > report/limits/service_limits.csv
  verbose "wrote 'report/limits/service_limits.csv'"
}

build_storage() {
  init_report_dirs
  require_tenancy
  ensure_compartments

  local -a regions
  regions=()
  while IFS= read -r region; do
    [[ -n "$region" ]] && regions+=("$region")
  done < <(resolve_target_regions)

  > report/storage/storage_inventory.jsonl
  > report/storage/block_backups.jsonl
  > report/storage/boot_backups.jsonl
  > report/storage/block_replicas.jsonl
  > report/storage/boot_replicas.jsonl
  echo "region,compartment-id,compartment-path" > report/storage/storage_target_compartments.csv

  local region
  for region in "${regions[@]}"; do
    local volume_targets
    local boot_targets
    local merged_targets
    volume_targets="report/storage/.storage_target_compartments_volume_${region}.csv"
    boot_targets="report/storage/.storage_target_compartments_boot_${region}.csv"
    merged_targets="report/storage/.storage_target_compartments_${region}.csv"

    search "query volume resources" "$volume_targets" "$region"
    search "query bootvolume resources" "$boot_targets" "$region"

    {
      echo "compartment-id,compartment-path"
      {
        tail -n +2 "$volume_targets"
        tail -n +2 "$boot_targets"
      } | sort -u
    } > "$merged_targets"

    while IFS=',' read -r cid cpath; do
      [[ "$cid" == "compartment-id" ]] && continue
      [[ -n "$cid" ]] || continue
      printf '%s,%s,%s\n' "$region" "$cid" "$cpath" >> report/storage/storage_target_compartments.csv
    done < "$merged_targets"

    progress_prefix "build_storage ${region}"
    local had_iterations="false"
    while IFS=',' read -r cid _; do
      [[ "$cid" == "compartment-id" ]] && continue
      [[ -n "$cid" ]] || continue
      progress_dot
      had_iterations="true"

      cpath="$(get_compartment_path "$cid")"

      oci bv volume list --compartment-id "$cid" --all --region "$region" --output json \
        | jq -c --arg region "$region" --arg cid "$cid" --arg cpath "$cpath" '
            .data[]? | {
              kind: "block-volume",
              region: $region,
              compartmentId: $cid,
              compartmentPath: $cpath,
              id: .id,
              displayName: ."display-name",
              lifecycleState: ."lifecycle-state",
              availabilityDomain: ."availability-domain",
              sizeInGBs: ."size-in-gbs",
              vpusPerGB: ."vpus-per-gb",
              autoTuneEnabled: ."is-auto-tune-enabled",
              kmsKeyId: ."kms-key-id",
              backupPolicyId: ."backup-policy-id",
              freeformTagCount: ((."freeform-tags" // {}) | keys | length),
              definedTagNamespaceCount: ((."defined-tags" // {}) | keys | length),
              timeCreated: ."time-created"
            }
          ' >> report/storage/storage_inventory.jsonl

      oci bv boot-volume list --compartment-id "$cid" --all --region "$region" --output json \
        | jq -c --arg region "$region" --arg cid "$cid" --arg cpath "$cpath" '
            .data[]? | {
              kind: "boot-volume",
              region: $region,
              compartmentId: $cid,
              compartmentPath: $cpath,
              id: .id,
              displayName: ."display-name",
              lifecycleState: ."lifecycle-state",
              availabilityDomain: ."availability-domain",
              sizeInGBs: ."size-in-gbs",
              vpusPerGB: null,
              autoTuneEnabled: null,
              kmsKeyId: ."kms-key-id",
              backupPolicyId: ."backup-policy-id",
              freeformTagCount: ((."freeform-tags" // {}) | keys | length),
              definedTagNamespaceCount: ((."defined-tags" // {}) | keys | length),
              timeCreated: ."time-created"
            }
          ' >> report/storage/storage_inventory.jsonl

      oci bv backup list --compartment-id "$cid" --all --region "$region" --output json \
        | jq -c '
            .data[]? | {
              sourceId: (."volume-id" // ."source-volume-id" // ""),
              timeCreated: ."time-created",
              backupType: (.type // ""),
              lifecycleState: ."lifecycle-state"
            } | select(.sourceId != "")
          ' >> report/storage/block_backups.jsonl

      oci bv boot-volume-backup list --compartment-id "$cid" --all --region "$region" --output json \
        | jq -c '
            .data[]? | {
              sourceId: (."boot-volume-id" // ."source-boot-volume-id" // ""),
              timeCreated: ."time-created",
              backupType: (.type // ""),
              lifecycleState: ."lifecycle-state"
            } | select(.sourceId != "")
          ' >> report/storage/boot_backups.jsonl

      oci bv block-volume-replica list --compartment-id "$cid" --all --region "$region" --output json \
        | jq -c '
            .data[]? | {
              sourceId: (."source-volume-id" // ."volume-id" // ."source-details".id // .sourceDetails.id // ""),
              lifecycleState: ."lifecycle-state"
            } | select(.sourceId != "")
          ' >> report/storage/block_replicas.jsonl

      oci bv boot-volume-replica list --compartment-id "$cid" --all --region "$region" --output json \
        | jq -c '
            .data[]? | {
              sourceId: (."source-boot-volume-id" // ."boot-volume-id" // ."source-details".id // .sourceDetails.id // ""),
              lifecycleState: ."lifecycle-state"
            } | select(.sourceId != "")
          ' >> report/storage/boot_replicas.jsonl
    done < "$merged_targets"
    progress_newline
    [[ "$had_iterations" == "true" ]] || true

    rm -f "$volume_targets" "$boot_targets" "$merged_targets"
  done

  {
    echo "region,compartment-id,compartment-path"
    tail -n +2 report/storage/storage_target_compartments.csv | sort -u
  } > report/storage/.storage_target_compartments_sorted.csv
  mv report/storage/.storage_target_compartments_sorted.csv report/storage/storage_target_compartments.csv
  verbose "wrote 'report/storage/storage_target_compartments.csv'"

  jq -s '
    group_by(.sourceId)
    | map({
        (.[0].sourceId): {
          backupCount: length,
          latestBackupTime: (map(.timeCreated) | max),
          latestBackupType: (sort_by(.timeCreated) | last | .backupType)
        }
      })
    | add // {}
  ' report/storage/block_backups.jsonl > report/storage/block_backup_index.json

  jq -s '
    group_by(.sourceId)
    | map({
        (.[0].sourceId): {
          backupCount: length,
          latestBackupTime: (map(.timeCreated) | max),
          latestBackupType: (sort_by(.timeCreated) | last | .backupType)
        }
      })
    | add // {}
  ' report/storage/boot_backups.jsonl > report/storage/boot_backup_index.json

  jq -s '
    group_by(.sourceId)
    | map({ (.[0].sourceId): {replicaCount: length} })
    | add // {}
  ' report/storage/block_replicas.jsonl > report/storage/block_replica_index.json

  jq -s '
    group_by(.sourceId)
    | map({ (.[0].sourceId): {replicaCount: length} })
    | add // {}
  ' report/storage/boot_replicas.jsonl > report/storage/boot_replica_index.json

  jq -s \
    --slurpfile blockBackups report/storage/block_backup_index.json \
    --slurpfile bootBackups report/storage/boot_backup_index.json \
    --slurpfile blockReplicas report/storage/block_replica_index.json \
    --slurpfile bootReplicas report/storage/boot_replica_index.json '
      map(
        . as $v
        | (if $v.kind == "block-volume" then ($blockBackups[0][$v.id] // {}) else ($bootBackups[0][$v.id] // {}) end) as $b
        | (if $v.kind == "block-volume" then ($blockReplicas[0][$v.id] // {}) else ($bootReplicas[0][$v.id] // {}) end) as $r
        | {
            region: $v.region,
            compartmentPath: $v.compartmentPath,
            kind: $v.kind,
            displayName: $v.displayName,
            id: $v.id,
            lifecycleState: $v.lifecycleState,
            availabilityDomain: $v.availabilityDomain,
            sizeInGBs: $v.sizeInGBs,
            vpusPerGB: $v.vpusPerGB,
            autoTuneEnabled: $v.autoTuneEnabled,
            kmsKeyId: $v.kmsKeyId,
            backupPolicyId: $v.backupPolicyId,
            backupCount: ($b.backupCount // 0),
            latestBackupTime: ($b.latestBackupTime // ""),
            latestBackupType: ($b.latestBackupType // ""),
            replicaCount: ($r.replicaCount // 0),
            drProtection: (if (($b.backupCount // 0) > 0 or ($r.replicaCount // 0) > 0 or ($v.backupPolicyId // "") != "") then "YES" else "NO" end),
            freeformTagCount: $v.freeformTagCount,
            definedTagNamespaceCount: $v.definedTagNamespaceCount,
            timeCreated: $v.timeCreated
          }
      )
      | sort_by(.kind, .region, .compartmentPath, .displayName)
    ' report/storage/storage_inventory.jsonl > report/storage/storage_inventory_enriched.json
  verbose "wrote 'report/storage/storage_inventory_enriched.json'"

  jq -r '
    [
      "region",
      "compartment-path",
      "kind",
      "display-name",
      "lifecycle-state",
      "availability-domain",
      "size-in-gbs",
      "vpus-per-gb",
      "auto-tune-enabled",
      "backup-policy-id",
      "backup-count",
      "latest-backup-time",
      "latest-backup-type",
      "replica-count",
      "dr-protection",
      "kms-key-id",
      "freeform-tag-count",
      "defined-tag-namespace-count",
      "time-created",
      "id"
    ],
    (
      .[] |
      [
        .region,
        .compartmentPath,
        .kind,
        .displayName,
        .lifecycleState,
        .availabilityDomain,
        .sizeInGBs,
        .vpusPerGB,
        .autoTuneEnabled,
        .backupPolicyId,
        .backupCount,
        .latestBackupTime,
        .latestBackupType,
        .replicaCount,
        .drProtection,
        .kmsKeyId,
        .freeformTagCount,
        .definedTagNamespaceCount,
        .timeCreated,
        .id
      ]
    ) | @csv
  ' report/storage/storage_inventory_enriched.json > report/storage/storage_inventory.csv
  verbose "wrote 'report/storage/storage_inventory.csv'"
}

main() {
  local cmd=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -d|--debug)
        DEBUG_MODE="true"
        ;;
      help|-h|--help)
        if [[ -z "$cmd" ]]; then
          cmd="help"
        else
          fatal "Unknown option: $1"
        fi
        ;;
      *)
        if [[ -z "$cmd" ]]; then
          cmd="$1"
        else
          fatal "Unknown option: $1"
        fi
        ;;
    esac
    shift
  done

  [[ -n "$cmd" ]] || cmd="help"
  [[ "$DEBUG_MODE" == "true" ]] && set -x

  require_cmd oci
  require_cmd jq
  require_cmd awk
  require_cmd sort

  case "$cmd" in
    regions)
      build_regions
      ;;
    compartments)
      build_compartments
      ;;
    policies)
      build_policies
      ;;
    compute)
      build_compute
      ;;
    block-storage)
      build_storage
      ;;
    limits)
      build_limits
      ;;
    all)
      build_compartments
      build_compute
      build_storage
      build_limits
      build_policies
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      fatal "Unknown command: $cmd"
      ;;
  esac
}

main "$@"
