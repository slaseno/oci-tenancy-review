  concat_compartment_parts "${out_dir}/compartments" "*.block_replicas.jsonl" "$block_replicas_jsonl"
  concat_compartment_parts "${out_dir}/compartments" "*.boot_replicas.jsonl" "$boot_replicas_jsonl"

  jq -s 'group_by(.sourceId) | map({(.[0].sourceId): {backupCount: length, latestBackupTime: (map(.timeCreated) | max), latestBackupType: (sort_by(.timeCreated) | last | .backupType)}}) | add // {}' "$block_backups_jsonl" > "${out_dir}/block_backup_index.json"
  jq -s 'group_by(.sourceId) | map({(.[0].sourceId): {backupCount: length, latestBackupTime: (map(.timeCreated) | max), latestBackupType: (sort_by(.timeCreated) | last | .backupType)}}) | add // {}' "$boot_backups_jsonl" > "${out_dir}/boot_backup_index.json"
  jq -s 'group_by(.sourceId) | map({ (.[0].sourceId): {replicaCount: length} }) | add // {}' "$block_replicas_jsonl" > "${out_dir}/block_replica_index.json"
  jq -s 'group_by(.sourceId) | map({ (.[0].sourceId): {replicaCount: length} }) | add // {}' "$boot_replicas_jsonl" > "${out_dir}/boot_replica_index.json"

  jq -s \
    --slurpfile blockBackups "${out_dir}/block_backup_index.json" \
    --slurpfile bootBackups "${out_dir}/boot_backup_index.json" \
    --slurpfile blockReplicas "${out_dir}/block_replica_index.json" \
    --slurpfile bootReplicas "${out_dir}/boot_replica_index.json" '
      map(
        . as $v
        | (if $v.kind == "block-volume" then ($blockBackups[0][$v.id] // {}) else ($bootBackups[0][$v.id] // {}) end) as $b
        | (if $v.kind == "block-volume" then ($blockReplicas[0][$v.id] // {}) else ($bootReplicas[0][$v.id] // {}) end) as $r
        | {
            region: $v.region,
            compartmentPath: $v.compartmentPath,
            compartmentId: $v.compartmentId,
            kind: $v.kind,
            displayName: $v.displayName,
            id: $v.id,
            lifecycleState: $v.lifecycleState,
            availabilityDomain: $v.availabilityDomain,
            sizeInGBs: $v.sizeInGBs,
            vpusPerGB: $v.vpusPerGB,
            isHydrated: $v.isHydrated,
            autoTuneEnabled: $v.autoTuneEnabled,
            autoTunedVpusPerGB: $v.autoTunedVpusPerGB,
            autotunePolicyCount: $v.autotunePolicyCount,
            volumeGroupId: $v.volumeGroupId,
            replicaAdList: $v.replicaAdList,
            imageId: $v.imageId,
            kmsKeyId: $v.kmsKeyId,
            backupPolicyId: $v.backupPolicyId,
            backupCount: ($b.backupCount // 0),
            latestBackupTime: ($b.latestBackupTime // ""),
            latestBackupType: ($b.latestBackupType // ""),
            replicaCount: ($r.replicaCount // 0),
            drProtection: (if (($b.backupCount // 0) > 0 or ($r.replicaCount // 0) > 0 or ($v.backupPolicyId // "") != "") then "YES" else "NO" end),
            freeformTagCount: $v.freeformTagCount,
            definedTagNamespaceCount: $v.definedTagNamespaceCount,
            timeCreated: $v.timeCreated
          }
      ) | sort_by(.kind, .region, .compartmentPath, .displayName)
    ' "$inventory_jsonl" > "${out_dir}/storage_inventory_enriched.json"

  jq -r '
    ["compartment-id","compartment-path","region","kind","display-name","lifecycle-state","availability-domain","size-in-gbs","vpus-per-gb","is-hydrated","auto-tune-enabled","auto-tuned-vpus-per-gb","autotune-policy-count","volume-group-id","replica-ad-list","backup-policy-id","backup-count","latest-backup-time","latest-backup-type","replica-count","dr-protection","kms-key-id","image-id","freeform-tag-count","defined-tag-namespace-count","time-created","id"],
    (.[] | [.compartmentId,.compartmentPath,.region,.kind,.displayName,.lifecycleState,.availabilityDomain,.sizeInGBs,.vpusPerGB,.isHydrated,.autoTuneEnabled,.autoTunedVpusPerGB,.autotunePolicyCount,.volumeGroupId,.replicaAdList,.backupPolicyId,.backupCount,.latestBackupTime,.latestBackupType,.replicaCount,.drProtection,.kmsKeyId,.imageId,.freeformTagCount,.definedTagNamespaceCount,.timeCreated,.id]) | @csv
  ' "${out_dir}/storage_inventory_enriched.json" > "${out_dir}/storage_inventory.csv"
  verbose "wrote region artifact dir '${out_dir}'"
  local total
  total="$(jq 'length' "${out_dir}/storage_inventory_enriched.json")"
  verbose "Done. ${total} disks in ${region}."
}

