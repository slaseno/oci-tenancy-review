#!/usr/bin/env bash

set -Eeuo pipefail

DEBUG_MODE="false"
CURRENT_TOP_COMMAND=""
RUN_LOG_FILE="${RUN_LOG_FILE:-report/run.log}"
COLORS_ENABLED="${COLORS_ENABLED:=$( (command -v tput > /dev/null 2>&1 && [[ $(tput -T"${TERM:-dumb}" colors 2>/dev/null || echo 0) -ge 8 ]] && echo "true") || echo "false")}"
COLOR_RED=$([ "$COLORS_ENABLED" == "true" ] && printf "\033[0;31m" || printf "")
COLOR_GREEN=$([ "$COLORS_ENABLED" == "true" ] && printf "\033[0;32m" || printf "")
COLOR_YELLOW=$([ "$COLORS_ENABLED" == "true" ] && printf "\033[0;33m" || printf "")
COLOR_GRAY=$([ "$COLORS_ENABLED" == "true" ] && printf "\033[0;90m" || printf "")
COLOR_END=$([ "$COLORS_ENABLED" == "true" ] && printf "\033[0m" || printf "")

usage() {
  cat <<USAGE
Usage: ./oci-tenancy-review <command> [args]

Commands:
  regions        Export reachable/non-blacklisted target region names to report/regions.txt
  compartments   Build tenancy compartment map at report/compartments.csv
  policies       Export tenancy policy statements to report/policies/policy_statements.csv
  compute        Export compute inventory to report/compute/compute_instances.csv
  compute-region Fetch compute inventory for one region to report/compute/regions/<region>/
  compute-merge  Merge region compute artifacts into report/compute/compute_instances.csv
  block-storage        Export block + boot volume inventory to report/storage/storage_inventory.csv
  block-storage-region Fetch block/boot inventory for one region to report/storage/regions/<region>/
  block-storage-merge  Merge region storage artifacts into report/storage/storage_inventory.csv
  base-database        Export base database inventory to report/base-database/base_databases.csv
  base-database-region Fetch base database inventory for one region to report/base-database/regions/<region>/
  base-database-merge  Merge region base database artifacts into report/base-database/base_databases.csv
  object-storage        Export object storage bucket inventory to report/object-storage/buckets_inventory.csv
  object-storage-region Fetch object storage inventory for one region to report/object-storage/regions/<region>/
  object-storage-merge  Merge region object storage artifacts into report/object-storage/buckets_inventory.csv
  compute-limits        Export compute service limits to report/limits/compute_limits.csv
  block-storage-limits  Export block-storage service limits to report/limits/block_storage_limits.csv
  object-storage-limits Export object-storage service limits to report/limits/object_storage_limits.csv
  limits                Export merged limits posture to report/limits/service_limits.csv
  limits-region         Fetch limits posture for one region to report/limits/regions/<region>/ (optional service scope)
  limits-merge          Merge service-specific limits artifacts into report/limits/service_limits.csv
  all            Run compartments + policies + compute + block-storage + base-database + object-storage + limits
  help           Show this help

Note:
  One command per invocation.
  The 'all' command delegates to Makefile parallel execution.
  Advanced parallel/cached execution is available via the repository Makefile.

Required environment:
  TENANCY_OCID   Tenancy OCID (ocid1.tenancy...)
Optional environment:
  DEBUG         Set to 'true' to enable bash xtrace output.
  RUN_LOG_FILE       Runtime log output path. Default: report/run.log
  REGIONS             Comma-separated region list for compute discovery (for example: eu-frankfurt-1,eu-zurich-1).
                      If unset, all subscribed regions are used.
  BLACKLISTED_REGIONS Comma-separated region blacklist for compute discovery.
                      Default: eu-kragujevac-1

Examples:
  export TENANCY_OCID="ocid1.tenancy.oc1...."
  ./oci-tenancy-review regions
  ./oci-tenancy-review compartments
  ./oci-tenancy-review policies
  ./oci-tenancy-review compute
  ./oci-tenancy-review compute-region eu-frankfurt-1
  ./oci-tenancy-review compute-merge
  ./oci-tenancy-review block-storage
  ./oci-tenancy-review block-storage-region eu-frankfurt-1
  ./oci-tenancy-review block-storage-merge
  ./oci-tenancy-review base-database
  ./oci-tenancy-review base-database-region eu-frankfurt-1
  ./oci-tenancy-review base-database-merge
  ./oci-tenancy-review object-storage
  ./oci-tenancy-review object-storage-region eu-frankfurt-1
  ./oci-tenancy-review object-storage-merge
  ./oci-tenancy-review limits
  ./oci-tenancy-review compute-limits
  ./oci-tenancy-review block-storage-limits
  ./oci-tenancy-review object-storage-limits
  ./oci-tenancy-review limits-region eu-frankfurt-1
  ./oci-tenancy-review limits-region eu-frankfurt-1 object-storage
  ./oci-tenancy-review limits-merge
  DEBUG=true ./oci-tenancy-review compute
  ./oci-tenancy-review all
USAGE
}

log() {
  local msg="$1"
  local ts
  ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  printf '%b%s [I] %s: %s%b\n' "$COLOR_GREEN" "$ts" "${FUNCNAME[1]}" "$msg" "$COLOR_END" >&2
}

verbose() {
  local msg="$1"
  local ts
  ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  printf '%b%s [V] %s: %s%b\n' "$COLOR_GRAY" "$ts" "${FUNCNAME[1]}" "$msg" "$COLOR_END" >&2
}

warn() {
  local msg="$1"
  local ts
  ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  printf '%b%s [W] %s: %s%b\n' "$COLOR_YELLOW" "$ts" "${FUNCNAME[1]}" "$msg" "$COLOR_END" >&2
}

fatal() {
  local msg="$1"
  local ts
  ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  printf '%b%s [F] %s: %s%b\n' "$COLOR_RED" "$ts" "${FUNCNAME[1]}" "$msg" "$COLOR_END" >&2
  exit 1
}


print_dot() {
  printf '.' >&2
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || fatal "Missing required command: $1"
}

write_run_log() {
  local rc="$1"
  shift
  local ts
  local oci_cmd
  local parent_dir
  ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  oci_cmd="$(printf '%q ' oci "$@")"
  oci_cmd="${oci_cmd% }"
  parent_dir="$(dirname "$RUN_LOG_FILE")"
  mkdir -p "$parent_dir" 2>/dev/null || true
  printf '%s\tcommand=%s\trc=%s\t%s\n' "$ts" "${CURRENT_TOP_COMMAND:-unknown}" "$rc" "$oci_cmd" >> "$RUN_LOG_FILE" 2>/dev/null || true
}

oci_cli() {
  local stderr_file
  local rc
  local stderr_text
  local stderr_text_lc
  local bailout_seconds
  local jitter_seconds
  local wait_seconds

  print_dot
  stderr_file="$(mktemp "${TMPDIR:-/tmp}/oci-review-stderr.XXXXXX")"
  if command oci "$@" 2>"$stderr_file"; then
    rc=0
  else
    rc=$?
  fi
  write_run_log "$rc" "$@"

  if [[ "$rc" -eq 0 ]]; then
    if [[ -s "$stderr_file" ]]; then
      cat "$stderr_file" >&2
    fi
    rm -f "$stderr_file"

    return 0
  fi

  stderr_text="$(cat "$stderr_file")"
  if [[ -n "$stderr_text" ]]; then
    printf '%s\n' "$stderr_text" >&2
  fi
  rm -f "$stderr_file"
  stderr_text_lc="$(printf '%s' "$stderr_text" | tr '[:upper:]' '[:lower:]')"

  if [[ "$stderr_text_lc" == *"status: 429"* ]] \
    || [[ "$stderr_text_lc" == *"requestexception"* ]] \
    || [[ "$stderr_text_lc" == *"timed out"* ]] \
    || [[ "$stderr_text_lc" == *"connection reset"* ]] \
    || [[ "$stderr_text_lc" == *"connection refused"* ]] \
    || [[ "$stderr_text_lc" == *"temporary failure"* ]] \
    || [[ "$stderr_text_lc" == *"name or service not known"* ]]; then
    bailout_seconds="${OCI_RETRY_BAILOUT_SECONDS:-2}"
    jitter_seconds=$((RANDOM % 2))
    wait_seconds=$((bailout_seconds + jitter_seconds))
    warn "oci call failed with retryable network condition; retrying once after ${wait_seconds}s"
    sleep "$wait_seconds"
    print_dot
    if command oci "$@"; then
      rc=0
    else
      rc=$?
    fi
    write_run_log "$rc" "$@"
    return "$rc"
  fi

  return "$rc"
}


init_report_dirs() {
  mkdir -p report report/compute report/policies report/limits report/storage report/base-database report/object-storage
}

require_tenancy() {
  [[ -n "${TENANCY_OCID:-}" ]] || fatal "TENANCY_OCID is required"
}

get_review_regions() {
  if [[ -z "${REGIONS:-}" ]]; then
    return 0
  fi

  echo "$REGIONS" \
    | tr ',' '\n' \
    | awk '{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0); if (length($0) > 0) print $0}'
}

get_all_subscribed_regions() {
  oci_cli iam region-subscription list \
    --tenancy-id "$TENANCY_OCID" \
    --all \
    --output json \
    | jq -r '.data[]?."region-name"'
}

get_blacklisted_regions() {
  if [[ -z "${BLACKLISTED_REGIONS+x}" ]]; then
    echo "eu-kragujevac-1"
    return 0
  fi

  echo "${BLACKLISTED_REGIONS}" \
    | tr ',' '\n' \
    | awk '{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0); if (length($0) > 0) print $0}'
}

is_blacklisted_region() {
  local region="$1"
  local blocked
  while IFS= read -r blocked; do
    [[ -n "$blocked" ]] || continue
    if [[ "$region" == "$blocked" ]]; then
      return 0
    fi
  done < <(get_blacklisted_regions)
  return 1
}

is_region_reachable() {
  local region="$1"
  oci_cli iam availability-domain list \
    --compartment-id "$TENANCY_OCID" \
    --region "$region" \
    --all \
    --output json >/dev/null
}

filter_reachable_regions() {
  verbose "filter_reachable_regions processing"
  local region
  for region in "$@"; do
    [[ -n "$region" ]] || continue
    if is_blacklisted_region "$region"; then
      warn "Skipping blacklisted region: $region"
      continue
    fi
    if is_region_reachable "$region"; then
      echo "$region"
    else
      warn "Skipping unreachable region: $region"
    fi
  done
}

resolve_target_regions() {
  if [[ -s report/regions.txt ]]; then
    verbose "using cached target regions from report/regions.txt"
    cat report/regions.txt
    return 0
  fi

  build_regions
}

resolve_target_regions_uncached() {
  local -a requested_regions
  local -a regions
  requested_regions=()
  if [[ -n "${REGIONS:-}" ]]; then
    while IFS= read -r region; do
      [[ -n "$region" ]] && requested_regions+=("$region")
    done < <(get_review_regions || true)
  else
    while IFS= read -r region; do
      [[ -n "$region" ]] && requested_regions+=("$region")
    done < <(get_all_subscribed_regions || true)
  fi

  regions=()
  if [[ "${#requested_regions[@]}" -gt 0 ]]; then
    while IFS= read -r region; do
      [[ -n "$region" ]] && regions+=("$region")
    done < <(filter_reachable_regions "${requested_regions[@]}")
  fi

  [[ "${#regions[@]}" -gt 0 ]] || fatal "No reachable regions from requested region set"
  log "regions to inspect: $(printf '%s ' "${regions[@]}" | sed 's/[[:space:]]*$//')"
  printf '%s\n' "${regions[@]}"
}

build_regions() {
  init_report_dirs
  require_tenancy

  resolve_target_regions_uncached > report/regions.txt
  verbose "wrote 'report/regions.txt'"
  cat report/regions.txt
  local total
  total="$(wc -l < report/regions.txt | tr -d ' ')"
  log "Done. ${total} regions."
}

build_compartments() {
  init_report_dirs
  require_tenancy

  oci_cli iam compartment list \
    --compartment-id "$TENANCY_OCID" \
    --compartment-id-in-subtree true \
    --access-level ANY \
    --include-root \
    --all \
    --output json > report/compartments.json

  {
    echo "compartment-id,compartment-path"
    jq -r --arg tenancy "$TENANCY_OCID" '
    .data as $d
    | ($d | map({key: .id, value: .}) | from_entries) as $m
    | def full_path($id):
        if $id == $tenancy then
          ""
        else
          (full_path($m[$id]."compartment-id")) as $p
          | if $p == "" then $m[$id].name else ($p + ":" + $m[$id].name) end
        end;
      [ $d[] | {id: .id, path: (if .id == $tenancy then "root" else full_path(.id) end)} ]
    | sort_by(if .path == "root" then "" else .path end)
    | .[]
    | .id + "," + .path
  ' report/compartments.json
  } > report/compartments.csv
  verbose "wrote 'report/compartments.json'"
  verbose "wrote 'report/compartments.csv'"

  total="$(tail -n +2 report/compartments.csv | wc -l | tr -d ' ')"
  log "Done. ${total} compartments."
}

ensure_compartments() {
  [[ -s report/compartments.csv ]] || build_compartments
}

get_compartment_path() {
  local cid="$1"
  awk -F',' -v cid="$cid" 'NR>1 && $1==cid {sub(/^[^,]*,/, "", $0); print $0; exit}' report/compartments.csv
}

write_compartment_path_file() {
  local cpath="$1"
  local cpath_file
  cpath_file="$(mktemp "${TMPDIR:-/tmp}/oci-review-cpath.XXXXXX")"
  printf '%s' "$cpath" > "$cpath_file"
  printf '%s\n' "$cpath_file"
}

build_region_limit_prefixes() {
  local region="$1"
  local out_file="$2"
  local compute_json_file="${3:-report/compute/compute_instances.json}"

  > "$out_file"
  jq -r --arg region "$region" '.[] | select(.region == $region) | .shape // empty' "$compute_json_file" \
    | while read -r shape; do
        local shape_lc
        shape_lc="$(echo "$shape" | tr '[:upper:]' '[:lower:]')"

        if [[ "$shape_lc" =~ ^(vm|bm)\.standard\.([a-z0-9]+)\.flex$ ]]; then
          local fam
          fam="${BASH_REMATCH[2]}"
          echo "standard-${fam}-" >> "$out_file"
          echo "vm-standard-${fam}-" >> "$out_file"
        fi

        if [[ "$shape_lc" =~ ^(vm|bm)\.standard([0-9]+)\..*$ ]]; then
          local gen
          gen="${BASH_REMATCH[2]}"
          echo "standard${gen}-" >> "$out_file"
          echo "vm-standard${gen}-" >> "$out_file"
        fi
      done

  sort -u "$out_file" -o "$out_file"
}

limit_matches_prefixes() {
  local limit_name="$1"
  local prefixes_file="$2"
  local p
  while IFS= read -r p; do
    [[ -n "$p" ]] || continue
    if [[ "$limit_name" == "$p"* ]]; then
      return 0
    fi
  done < "$prefixes_file"
  return 1
}

search() {
  local query_text="$1"
  local out_file="$2"
  local resource_count=0
  shift 2
  local regions=("$@")
  if [[ "${#regions[@]}" -eq 0 ]]; then
    regions=("")
  fi
  local tmp_dir
  tmp_dir="$(dirname "$out_file")"
  local resp_file="${tmp_dir}/.search_response.json"
  local extracted_file="${tmp_dir}/.search_compartments.tmp"
  local ids_file="${out_file}.ids"

  > "$ids_file"
  local region page
  for region in "${regions[@]}"; do
    page=""
    verbose "search '${query_text}' ${region:-default-region} processing"
    while true; do
      local -a args
      args=(
        search resource structured-search
        --query-text "$query_text"
        --limit 1000
      )
      [[ -n "$page" ]] && args+=(--page "$page")
      [[ -n "$region" ]] && args+=(--region "$region")
      args+=(--output json)
      oci_cli "${args[@]}" > "$resp_file"

      jq -e '.' "$resp_file" >/dev/null 2>&1 || \
        fatal "Search query returned non-JSON output for: $query_text"

      jq -r '
        if (.data | type) == "array" then
          .data[]
        elif (.data | type) == "object" and ((.data.items | type) == "array") then
          .data.items[]
        elif (.items | type) == "array" then
          .items[]
        else
          empty
        end
        | (."compartment-id" // .compartmentId // .compartment_id // empty)
      ' "$resp_file" > "$extracted_file"

      resource_count=$((resource_count + $(wc -l < "$extracted_file")))
      cat "$extracted_file" >> "$ids_file"

      page="$(jq -r '."opc-next-page" // empty' "$resp_file")"
      [[ -z "$page" ]] && break
    done
  done

  sort -u "$ids_file" -o "$ids_file"
  rm -f "$resp_file" "$extracted_file"

  {
    echo "compartment-id,compartment-path"
    while read -r cid; do
      [[ -n "$cid" ]] || continue
      cpath="$(get_compartment_path "$cid")"
      printf '%s,%s\n' "$cid" "$cpath"
    done < "$ids_file"
  } > "$out_file"
  verbose "wrote '$out_file'"

  local target_compartments
  target_compartments="$(tail -n +2 "$out_file" | wc -l | tr -d ' ')"
  verbose "search '${query_text}' returned ${resource_count} resources in ${target_compartments} compartments (regions=${regions})."

  rm -f "$ids_file"
}

build_policies() {
  local cid
  prepare_policies
  while IFS= read -r cid; do
    [[ -n "$cid" ]] || continue
    build_policy_compartment "$cid" "report/policies/compartments/${cid}.jsonl"
  done < report/policies/.policy_cids.txt
  merge_policies
}

prepare_policies() {
  init_report_dirs
  require_tenancy
  ensure_compartments

  mkdir -p report/policies/compartments
  rm -f report/policies/compartments/*.jsonl

  search \
    "query policy resources" \
    "report/policies/policy_target_compartments.csv"

  write_cids_from_targets_csv report/policies/policy_target_compartments.csv report/policies/.policy_cids.txt
  local total
  total="$(wc -l < report/policies/.policy_cids.txt | tr -d ' ')"
  log "Done. ${total} target compartments."
}

build_policy_compartment() {
  local cid="$1"
  local out_file="$2"
  local cpath
  local cpath_file
  cpath="$(get_compartment_path "$cid")"
  cpath_file="$(write_compartment_path_file "$cpath")"
  oci_cli iam policy list -c "$cid" --all --output json \
    | jq -c --arg cid "$cid" --rawfile cpath "$cpath_file" '
        .data[]? | {
          compartmentId: $cid,
          compartmentPath: $cpath,
          name: .name,
          id: .id,
          description: (.description // ""),
          lifecycleState: ."lifecycle-state",
          timeCreated: ."time-created",
          freeformTags: ."freeform-tags",
          definedTags: ."defined-tags",
          statements: .statements
        }
      ' > "$out_file"
  rm -f "$cpath_file"
}

merge_policies() {
  mkdir -p report/policies/compartments
  concat_compartment_parts report/policies/compartments "*.jsonl" report/policies/policies_all_compartments.jsonl

  jq -s '.' report/policies/policies_all_compartments.jsonl > report/policies/policies_all_compartments.json
  verbose "wrote 'report/policies/policies_all_compartments.json'"

  jq -r '
    ["compartment-id","compartment-path","statement-seq","policy-name","policy-statement","created-by","time-created","policy-lifecycle-state","policy-description","policy-freeform-tag-count","policy-defined-tag-namespace-count","id"],
    (.[] as $p | (($p.statements // []) | to_entries[]) as $s |
      [
        $p.compartmentId,
        $p.compartmentPath,
        ($s.key + 1),
        $p.name,
        $s.value,
        ($p.definedTags["Oracle-Tags"]["CreatedBy"] // ""),
        $p.timeCreated,
        $p.lifecycleState,
        ($p.description // ""),
        (($p.freeformTags // {}) | keys | length),
        (($p.definedTags // {}) | keys | length),
        $p.id
      ]
    ) | @csv
  ' report/policies/policies_all_compartments.json > report/policies/policy_statements.csv
  verbose "wrote 'report/policies/policy_statements.csv'"
  local total
  total="$(tail -n +2 report/policies/policy_statements.csv | wc -l | tr -d ' ')"
  log "Done. ${total} policy statements."
}

build_compute() {
  init_report_dirs
  require_tenancy
  ensure_compartments
  ensure_target_regions
  local region
  while IFS= read -r region; do
    [[ -n "$region" ]] || continue
    build_compute_region "$region"
  done < <(resolve_target_regions)
  merge_compute_regions
}

ensure_target_regions() {
  [[ -s report/regions.txt ]] || build_regions
}

collect_target_regions_array() {
  local region
  TARGET_REGIONS=()
  while IFS= read -r region; do
    [[ -n "$region" ]] && TARGET_REGIONS+=("$region")
  done < <(resolve_target_regions)
}

write_cids_from_targets_csv() {
  local targets_file="$1"
  local cid_file="$2"
  awk -F',' 'NR>1 && $1 != "" {print $1}' "$targets_file" > "$cid_file"
}

concat_compartment_parts() {
  local parts_dir="$1"
  local suffix_pattern="$2"
  local out_file="$3"
  local -a part_files
  : > "$out_file"
  shopt -s nullglob
  part_files=("${parts_dir}"/${suffix_pattern})
  shopt -u nullglob
  if [[ "${#part_files[@]}" -gt 0 ]]; then
    cat "${part_files[@]}" >> "$out_file"
  fi
}

build_compute_compartment_region() {
  local region="$1"
  local cid="$2"
  local out_file="$3"
  local cpath
  local cpath_file
  cpath="$(get_compartment_path "$cid")"
  cpath_file="$(write_compartment_path_file "$cpath")"
  oci_cli compute instance list --compartment-id "$cid" --all --region "$region" --output json \
    | jq -c --arg cid "$cid" --rawfile cpath "$cpath_file" '
        .data[]? | {
          compartmentId: $cid,
          compartmentPath: $cpath,
          region: .region,
          instanceId: .id,
          instanceName: ."display-name",
          shape: .shape,
          ocpus: ."shape-config".ocpus,
          memoryInGBs: ."shape-config"."memory-in-gbs",
          baselineOcpuUtilization: ."shape-config"."baseline-ocpu-utilization",
          lifecycleState: ."lifecycle-state",
          availabilityDomain: ."availability-domain",
          faultDomain: ."fault-domain",
          imageId: ."image-id",
          launchMode: ."launch-mode",
          sourceType: ."source-details"."source-type",
          capacityReservationId: ."capacity-reservation-id",
          dedicatedVmHostId: ."dedicated-vm-host-id",
          timeMaintenanceRebootDue: ."time-maintenance-reboot-due",
          preemptibleActionType: ."preemptible-instance-config"."preemption-action"."type",
          availabilityRecoveryAction: ."availability-config"."recovery-action",
          legacyImdsEndpointsDisabled: ."instance-options"."are-legacy-imds-endpoints-disabled",
          networkType: ."launch-options"."network-type",
          launchBootVolumeType: ."launch-options"."boot-volume-type",
          launchFirmware: ."launch-options".firmware,
          launchRemoteDataVolumeType: ."launch-options"."remote-data-volume-type",
          consistentVolumeNamingEnabled: ."launch-options"."is-consistent-volume-naming-enabled",
          allPluginsDisabled: ."agent-config"."are-all-plugins-disabled",
          monitoringDisabled: ."agent-config"."is-monitoring-disabled",
          managementDisabled: ."agent-config"."is-management-disabled",
          liveMigrationPreferred: ."is-live-migration-preferred",
          pvEncryptionInTransitEnabled: ."is-pv-encryption-in-transit-enabled",
          metadataKeyCount: ((.metadata // {}) | keys | length),
          extendedMetadataKeyCount: ((."extended-metadata" // {}) | keys | length),
          platformType: ."platform-config".type,
          platformSecureBootEnabled: ."platform-config"."is-secure-boot-enabled",
          platformTrustedPlatformModuleEnabled: ."platform-config"."is-trusted-platform-module-enabled",
          platformMeasuredBootEnabled: ."platform-config"."is-measured-boot-enabled",
          platformMemoryEncryptionEnabled: ."platform-config"."is-memory-encryption-enabled",
          freeformTagCount: ((."freeform-tags" // {}) | keys | length),
