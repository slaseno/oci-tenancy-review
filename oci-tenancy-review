build_object_storage_compartment_region() {
  local region="$1"
  local cid="$2"
  local out_file="$3"
  local namespace="$4"
  local cpath
  local cpath_file
  local bucket_summary bucket_name bucket_namespace bucket_detail
  cpath="$(get_compartment_path "$cid")"
  cpath_file="$(write_compartment_path_file "$cpath")"
  : > "$out_file"
  while IFS= read -r bucket_summary; do
    [[ -n "$bucket_summary" ]] || continue
    bucket_name="$(jq -r '.name // empty' <<< "$bucket_summary")"
    [[ -n "$bucket_name" ]] || continue
    bucket_namespace="$(jq -r --arg ns "$namespace" '.namespace // $ns' <<< "$bucket_summary")"
    bucket_detail="$(oci_cli os bucket get --bucket-name "$bucket_name" --namespace-name "$bucket_namespace" --region "$region" --fields approximateCount --fields approximateSize --fields autoTiering --output json | jq -c '.data // {}')"
    jq -cn --arg region "$region" --arg cid "$cid" --rawfile cpath "$cpath_file" --arg ns "$namespace" --argjson summary "$bucket_summary" --argjson detail "$bucket_detail" '
      {
        compartmentId: $cid,
        compartmentPath: $cpath,
        region: $region,
        namespace: ($summary.namespace // $ns),
        bucketName: $summary.name,
        bucketCreatedBy: $summary."created-by",
        timeCreated: $summary."time-created",
        etag: $summary.etag,
        freeformTagCount: (($summary."freeform-tags" // {}) | keys | length),
        definedTagNamespaceCount: (($summary."defined-tags" // {}) | keys | length),
        freeformTagKeys: (($summary."freeform-tags" // {}) | keys | sort | join(";")),
        definedTagNamespaces: (($summary."defined-tags" // {}) | keys | sort | join(";")),
        definedTagKeyCount: ((($summary."defined-tags" // {}) | to_entries | map((.value // {}) | keys | length) | add) // 0),
        freeformTagsJson: (($summary."freeform-tags" // {}) | tojson),
        definedTagsJson: (($summary."defined-tags" // {}) | tojson),
        bucketId: ($detail.id // ""),
        publicAccessType: ($detail."public-access-type" // ""),
        storageTier: ($detail."storage-tier" // ""),
        objectEventsEnabled: ($detail."object-events-enabled" // false),
        replicationEnabled: ($detail."replication-enabled" // false),
        isReadOnly: ($detail."is-read-only" // false),
        versioning: ($detail.versioning // ""),
        autoTiering: ($detail."auto-tiering" // ""),
        kmsKeyId: ($detail."kms-key-id" // ""),
        approximateObjectCount: ($detail."approximate-count" // 0),
        approximateSizeBytes: ($detail."approximate-size" // 0),
