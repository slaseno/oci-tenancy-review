#!/usr/bin/env bash

set -Eeuo pipefail

VERSION="0.1.0"
DEBUG_MODE="false"
COLORS_ENABLED="${COLORS_ENABLED:=$( (command -v tput > /dev/null 2>&1 && [[ $(tput -T"${TERM:-dumb}" colors 2>/dev/null || echo 0) -ge 8 ]] && echo "true") || echo "false")}"
COLOR_RED=$([ "$COLORS_ENABLED" == "true" ] && printf "\033[0;31m" || printf "")
COLOR_GREEN=$([ "$COLORS_ENABLED" == "true" ] && printf "\033[0;32m" || printf "")
COLOR_YELLOW=$([ "$COLORS_ENABLED" == "true" ] && printf "\033[0;33m" || printf "")
COLOR_GRAY=$([ "$COLORS_ENABLED" == "true" ] && printf "\033[0;90m" || printf "")
COLOR_END=$([ "$COLORS_ENABLED" == "true" ] && printf "\033[0m" || printf "")

usage() {
  cat <<USAGE
Usage: ./oci-tenancy-review <command> [-d|--debug]
Version: ${VERSION}

Commands:
  regions        Export reachable/non-blacklisted target region names to report/regions.txt
  compartments   Build tenancy compartment map at report/compartments.csv
  policies       Export tenancy policy statements to report/policies/policy_statements.csv
  compute        Export compute inventory to report/compute/compute_instances.csv
  compute-region Fetch compute inventory for one region to report/compute/regions/<region>/
  compute-merge  Merge region compute artifacts into report/compute/compute_instances.csv
  block-storage        Export block + boot volume inventory to report/storage/storage_inventory.csv
  block-storage-region Fetch block/boot inventory for one region to report/storage/regions/<region>/
  block-storage-merge  Merge region storage artifacts into report/storage/storage_inventory.csv
  limits         Export compute + block-storage limits posture to report/limits/service_limits.csv
  limits-region  Fetch limits posture for one region to report/limits/regions/<region>/
  limits-merge   Merge region limits artifacts into report/limits/service_limits.csv
  all            Run compartments + policies + compute + block-storage + limits
  help           Show this help

Required environment:
  TENANCY_OCID   Tenancy OCID (ocid1.tenancy...)
Optional environment:
  OCI_REVIEW_REGIONS  Comma-separated region list for compute discovery (for example: eu-frankfurt-1,eu-zurich-1).
                      If unset, all subscribed regions are used.
  BLACKLISTED_REGIONS Comma-separated region blacklist for compute discovery.
                      Default: eu-kragujevac-1

Examples:
  export TENANCY_OCID="ocid1.tenancy.oc1...."
  ./oci-tenancy-review regions
  ./oci-tenancy-review compartments
  ./oci-tenancy-review policies
  ./oci-tenancy-review compute
  ./oci-tenancy-review compute-region eu-frankfurt-1
  ./oci-tenancy-review compute-merge
  ./oci-tenancy-review block-storage
  ./oci-tenancy-review block-storage-region eu-frankfurt-1
  ./oci-tenancy-review block-storage-merge
  ./oci-tenancy-review limits
  ./oci-tenancy-review limits-region eu-frankfurt-1
  ./oci-tenancy-review limits-merge
  ./oci-tenancy-review compute --debug
  ./oci-tenancy-review all
USAGE
}

log() {
  local msg="$1"
  printf '%b[I] %s: %s%b\n' "$COLOR_GREEN" "${FUNCNAME[1]}" "$msg" "$COLOR_END" >&2
}

verbose() {
  local msg="$1"
  printf '%b[V] %s: %s%b\n' "$COLOR_GRAY" "${FUNCNAME[1]}" "$msg" "$COLOR_END" >&2
}

warn() {
  local msg="$1"
  printf '%b[W] %s: %s%b\n' "$COLOR_YELLOW" "${FUNCNAME[1]}" "$msg" "$COLOR_END" >&2
}

err() {
  local msg="$1"
  printf '%b[E] %s: %s%b\n' "$COLOR_RED" "${FUNCNAME[1]}" "$msg" "$COLOR_END" >&2
}

fatal() {
  local msg="$1"
  printf '%b[F] %s: %s%b\n' "$COLOR_RED" "${FUNCNAME[1]}" "$msg" "$COLOR_END" >&2
  exit 1
}


progress_dot() {
  [[ "$DEBUG_MODE" == "true" ]] || printf '.' >&2
}

progress_prefix() {
  local message="$1"
  [[ "$DEBUG_MODE" == "true" ]] || printf '%b[I] %s %b' "$COLOR_GREEN" "$message" "$COLOR_END" >&2
}

progress_newline() {
  if [[ "$DEBUG_MODE" == "true" ]]; then
    return 0
  fi
  printf '\n' >&2
  return 0
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || fatal "Missing required command: $1"
}

is_rate_limited_error() {
  local msg="$1"
  local msg_lc
  msg_lc="$(printf '%s' "$msg" | tr '[:upper:]' '[:lower:]')"

  [[ "$msg_lc" == *"toomanyrequests"* ]] && return 0
  [[ "$msg_lc" == *"status: 429"* ]] && return 0
  [[ "$msg_lc" == *"status': 429"* ]] && return 0
  [[ "$msg_lc" == *'status": 429'* ]] && return 0
  [[ "$msg_lc" == *"rate limit"* ]] && return 0
  [[ "$msg_lc" == *"throttl"* ]] && return 0
  return 1
}

oci_cli() {
  local stderr_file
  local rc
  local stderr_text
  local bailout_seconds
  local jitter_seconds
  local wait_seconds

  stderr_file="$(mktemp "${TMPDIR:-/tmp}/oci-review-stderr.XXXXXX")"
  if command oci "$@" 2>"$stderr_file"; then
    rc=0
  else
    rc=$?
  fi

  if [[ "$rc" -eq 0 ]]; then
    if [[ -s "$stderr_file" ]]; then
      cat "$stderr_file" >&2
    fi
    rm -f "$stderr_file"
    return 0
  fi

  stderr_text="$(cat "$stderr_file")"
  if [[ -n "$stderr_text" ]]; then
    printf '%s\n' "$stderr_text" >&2
  fi
  rm -f "$stderr_file"

  if is_rate_limited_error "$stderr_text"; then
    bailout_seconds="${OCI_RATE_LIMIT_BAILOUT_SECONDS:-2}"
    jitter_seconds=$((RANDOM % 2))
    wait_seconds=$((bailout_seconds + jitter_seconds))
    warn "oci call rate-limited; retrying once after ${wait_seconds}s: oci $*"
    sleep "$wait_seconds"
    command oci "$@"
    return $?
  fi

  return "$rc"
}


init_report_dirs() {
  mkdir -p report report/compute report/policies report/limits report/storage
}

require_tenancy() {
  [[ -n "${TENANCY_OCID:-}" ]] || fatal "TENANCY_OCID is required"
}

get_review_regions() {
  if [[ -z "${OCI_REVIEW_REGIONS:-}" ]]; then
    return 0
  fi

  echo "$OCI_REVIEW_REGIONS" \
    | tr ',' '\n' \
    | awk '{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0); if (length($0) > 0) print $0}'
}

get_all_subscribed_regions() {
  oci_cli iam region-subscription list \
    --tenancy-id "$TENANCY_OCID" \
    --all \
    --output json \
    | jq -r '.data[]?."region-name"'
}

get_blacklisted_regions() {
  if [[ -z "${BLACKLISTED_REGIONS+x}" ]]; then
    echo "eu-kragujevac-1"
    return 0
  fi

  echo "${BLACKLISTED_REGIONS}" \
    | tr ',' '\n' \
    | awk '{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0); if (length($0) > 0) print $0}'
}

is_blacklisted_region() {
  local region="$1"
  local blocked
  while IFS= read -r blocked; do
    [[ -n "$blocked" ]] || continue
    if [[ "$region" == "$blocked" ]]; then
      return 0
    fi
  done < <(get_blacklisted_regions)
  return 1
}

is_region_reachable() {
  local region="$1"
  oci_cli iam availability-domain list \
    --compartment-id "$TENANCY_OCID" \
    --region "$region" \
    --all \
    --output json >/dev/null
}

filter_reachable_regions() {
  progress_prefix "filter_reachable_regions processing"
  local region
  local had_iterations="false"
  for region in "$@"; do
    progress_dot
    had_iterations="true"
    [[ -n "$region" ]] || continue
    if is_blacklisted_region "$region"; then
      progress_newline
      warn "Skipping blacklisted region: $region"
      continue
    fi
    if is_region_reachable "$region"; then
      echo "$region"
    else
      progress_newline
      warn "Skipping unreachable region: $region"
    fi
  done
  if [[ "$had_iterations" == "true" ]]; then
    progress_newline
  fi
}

resolve_target_regions() {
  if [[ -s report/regions.txt ]]; then
    log "using cached target regions from report/regions.txt"
    cat report/regions.txt
    return 0
  fi

  build_regions
}

resolve_target_regions_uncached() {
  local -a requested_regions
  local -a regions
  requested_regions=()
  if [[ -n "${OCI_REVIEW_REGIONS:-}" ]]; then
    while IFS= read -r region; do
      [[ -n "$region" ]] && requested_regions+=("$region")
    done < <(get_review_regions || true)
  else
    while IFS= read -r region; do
      [[ -n "$region" ]] && requested_regions+=("$region")
    done < <(get_all_subscribed_regions || true)
  fi

  regions=()
  if [[ "${#requested_regions[@]}" -gt 0 ]]; then
    while IFS= read -r region; do
      [[ -n "$region" ]] && regions+=("$region")
    done < <(filter_reachable_regions "${requested_regions[@]}")
  fi

  [[ "${#regions[@]}" -gt 0 ]] || fatal "No reachable regions from requested region set"
  log "regions to inspect: $(printf '%s ' "${regions[@]}" | sed 's/[[:space:]]*$//')"
  printf '%s\n' "${regions[@]}"
}

build_regions() {
  init_report_dirs
  require_tenancy

  resolve_target_regions_uncached > report/regions.txt
  verbose "wrote 'report/regions.txt'"
  cat report/regions.txt
}

build_compartments() {
  init_report_dirs
  require_tenancy

  oci_cli iam compartment list \
    --compartment-id "$TENANCY_OCID" \
    --compartment-id-in-subtree true \
    --access-level ANY \
    --include-root \
    --all \
    --output json > report/compartments.json

  {
    echo "compartment-id,compartment-path"
    jq -r --arg tenancy "$TENANCY_OCID" '
    .data as $d
    | ($d | map({key: .id, value: .}) | from_entries) as $m
    | def full_path($id):
        if $id == $tenancy then
          ""
        else
          (full_path($m[$id]."compartment-id")) as $p
          | if $p == "" then $m[$id].name else ($p + "." + $m[$id].name) end
        end;
      [ $d[] | {id: .id, path: (if .id == $tenancy then "root" else full_path(.id) end)} ]
    | sort_by(if .path == "root" then "" else .path end)
    | .[]
    | .id + "," + .path
  ' report/compartments.json
  } > report/compartments.csv
  verbose "wrote 'report/compartments.json'"
  verbose "wrote 'report/compartments.csv'"

  total_compartments="$(tail -n +2 report/compartments.csv | wc -l | tr -d ' ')"
  log "${total_compartments} total compartments."
}

ensure_compartments() {
  [[ -s report/compartments.csv ]] || build_compartments
}

get_compartment_path() {
  local cid="$1"
  awk -F',' -v cid="$cid" 'NR>1 && $1==cid {sub(/^[^,]*,/, "", $0); print $0; exit}' report/compartments.csv
}

build_region_limit_prefixes() {
  local region="$1"
  local out_file="$2"
  local compute_json_file="${3:-report/compute/compute_instances.json}"

  > "$out_file"
  jq -r --arg region "$region" '.[] | select(.region == $region) | .shape // empty' "$compute_json_file" \
    | while read -r shape; do
        local shape_lc
        shape_lc="$(echo "$shape" | tr '[:upper:]' '[:lower:]')"

        if [[ "$shape_lc" =~ ^(vm|bm)\.standard\.([a-z0-9]+)\.flex$ ]]; then
          local fam
          fam="${BASH_REMATCH[2]}"
          echo "standard-${fam}-" >> "$out_file"
          echo "vm-standard-${fam}-" >> "$out_file"
        fi

        if [[ "$shape_lc" =~ ^(vm|bm)\.standard([0-9]+)\..*$ ]]; then
          local gen
          gen="${BASH_REMATCH[2]}"
          echo "standard${gen}-" >> "$out_file"
          echo "vm-standard${gen}-" >> "$out_file"
        fi
      done

  sort -u "$out_file" -o "$out_file"
}

limit_matches_prefixes() {
  local limit_name="$1"
  local prefixes_file="$2"
  local p
  while IFS= read -r p; do
    [[ -n "$p" ]] || continue
    if [[ "$limit_name" == "$p"* ]]; then
      return 0
    fi
  done < "$prefixes_file"
  return 1
}

search() {
  local query_text="$1"
  local out_file="$2"
  local resource_count=0
  shift 2
  local regions=("$@")
  if [[ "${#regions[@]}" -eq 0 ]]; then
    regions=("")
  fi
  local tmp_dir
  tmp_dir="$(dirname "$out_file")"
  local resp_file="${tmp_dir}/.search_response.json"
  local extracted_file="${tmp_dir}/.search_compartments.tmp"
  local ids_file="${out_file}.ids"

  > "$ids_file"
  local region page
  for region in "${regions[@]}"; do
    page=""
    progress_prefix "search '${query_text}' ${region:-default-region} processing"
    local had_iterations="false"
    while true; do
      progress_dot
      had_iterations="true"
      if [[ -n "$region" && -n "$page" ]]; then
        oci_cli search resource structured-search \
          --query-text "$query_text" \
          --limit 1000 \
          --page "$page" \
          --region "$region" \
          --output json > "$resp_file"
      elif [[ -n "$region" ]]; then
        oci_cli search resource structured-search \
          --query-text "$query_text" \
          --limit 1000 \
          --region "$region" \
          --output json > "$resp_file"
      elif [[ -n "$page" ]]; then
        oci_cli search resource structured-search \
          --query-text "$query_text" \
          --limit 1000 \
          --page "$page" \
          --output json > "$resp_file"
      else
        oci_cli search resource structured-search \
          --query-text "$query_text" \
          --limit 1000 \
          --output json > "$resp_file"
      fi

      jq -e '.' "$resp_file" >/dev/null 2>&1 || \
        fatal "Search query returned non-JSON output for: $query_text"

      jq -r '
        if (.data | type) == "array" then
          .data[]
        elif (.data | type) == "object" and ((.data.items | type) == "array") then
          .data.items[]
        elif (.items | type) == "array" then
          .items[]
        else
          empty
        end
        | (."compartment-id" // .compartmentId // .compartment_id // empty)
      ' "$resp_file" > "$extracted_file"

      resource_count=$((resource_count + $(wc -l < "$extracted_file")))
      cat "$extracted_file" >> "$ids_file"

      page="$(jq -r '."opc-next-page" // empty' "$resp_file")"
      [[ -z "$page" ]] && break
    done
    progress_newline
  done

  sort -u "$ids_file" -o "$ids_file"
  rm -f "$resp_file" "$extracted_file"

  {
    echo "compartment-id,compartment-path"
    while read -r cid; do
      [[ -n "$cid" ]] || continue
      cpath="$(get_compartment_path "$cid")"
      printf '%s,%s\n' "$cid" "$cpath"
    done < "$ids_file"
  } > "$out_file"
  verbose "wrote '$out_file'"

  local target_compartments
  target_compartments="$(tail -n +2 "$out_file" | wc -l | tr -d ' ')"
  log "search '${query_text}' returned ${resource_count} resources in ${target_compartments} compartments (regions=${regions})."

  rm -f "$ids_file"
}

build_policies() {
  init_report_dirs
  require_tenancy
  ensure_compartments

  search \
    "query policy resources" \
    "report/policies/policy_target_compartments.csv"

  > report/policies/policies_all_compartments.jsonl
  progress_prefix "build_policies processing"
  local had_policy_iterations="false"
  while IFS=',' read -r cid _; do
    [[ "$cid" == "compartment-id" ]] && continue
    [[ -n "$cid" ]] || continue
    progress_dot
    had_policy_iterations="true"
    cpath="$(get_compartment_path "$cid")"
    oci_cli iam policy list -c "$cid" --all --output json \
      | jq -c --arg cid "$cid" --arg cpath "$cpath" '
          .data[]? | {
            compartmentId: $cid,
            compartmentPath: $cpath,
            name: .name,
            id: .id,
            timeCreated: ."time-created",
            definedTags: ."defined-tags",
            statements: .statements
          }
        ' >> report/policies/policies_all_compartments.jsonl
  done < report/policies/policy_target_compartments.csv
  progress_newline

  jq -s '.' report/policies/policies_all_compartments.jsonl > report/policies/policies_all_compartments.json
  verbose "wrote 'report/policies/policies_all_compartments.json'"

  jq -r '
    ["compartment-id","compartment-name","policy-name","created-by","time-created","the actual statement","id"],
    (.[] as $p | ($p.statements // [])[] |
      [$p.compartmentId, $p.compartmentPath, $p.name, ($p.definedTags["Oracle-Tags"]["CreatedBy"] // ""), $p.timeCreated, ., $p.id]
    ) | @csv
  ' report/policies/policies_all_compartments.json > report/policies/policy_statements.csv
  verbose "wrote 'report/policies/policy_statements.csv'"
}

build_compute() {
  init_report_dirs
  require_tenancy
  ensure_compartments
  ensure_target_regions
  local -a regions
  regions=()
  while IFS= read -r region; do
    [[ -n "$region" ]] && regions+=("$region")
  done < <(resolve_target_regions)

  > report/compute/compute_instances.jsonl
  local region
  for region in "${regions[@]}"; do
    local region_dir
    local region_target_file
    region_dir="report/compute/regions/${region}"
    mkdir -p "$region_dir"
    region_target_file="${region_dir}/compute_target_compartments_${region}.csv"

    search \
      "query instance resources" \
      "$region_target_file" \
      "$region"

    progress_prefix "build_compute processing ${region}"
    local had_compute_iterations="false"
    while IFS=',' read -r cid _; do
      [[ "$cid" == "compartment-id" ]] && continue
      [[ -n "$cid" ]] || continue
      progress_dot
      had_compute_iterations="true"
      cpath="$(get_compartment_path "$cid")"
      oci_cli compute instance list --compartment-id "$cid" --all --region "$region" --output json \
        | jq -c --arg cid "$cid" --arg cpath "$cpath" '
            .data[]? | {
              compartmentId: $cid,
              compartmentPath: $cpath,
              region: .region,
              instanceId: .id,
              instanceName: ."display-name",
              shape: .shape,
              ocpus: ."shape-config".ocpus,
              memoryInGBs: ."shape-config"."memory-in-gbs",
              baselineOcpuUtilization: ."shape-config"."baseline-ocpu-utilization",
              lifecycleState: ."lifecycle-state",
              availabilityDomain: ."availability-domain",
              faultDomain: ."fault-domain",
              imageId: ."image-id",
              launchMode: ."launch-mode",
              sourceType: ."source-details"."source-type",
              capacityReservationId: ."capacity-reservation-id",
              dedicatedVmHostId: ."dedicated-vm-host-id",
              preemptibleActionType: ."preemptible-instance-config"."preemption-action"."type",
              availabilityRecoveryAction: ."availability-config"."recovery-action",
              legacyImdsEndpointsDisabled: ."instance-options"."are-legacy-imds-endpoints-disabled",
              networkType: ."launch-options"."network-type",
              consistentVolumeNamingEnabled: ."launch-options"."is-consistent-volume-naming-enabled",
              monitoringDisabled: ."agent-config"."is-monitoring-disabled",
              managementDisabled: ."agent-config"."is-management-disabled",
              liveMigrationPreferred: ."is-live-migration-preferred",
              pvEncryptionInTransitEnabled: ."is-pv-encryption-in-transit-enabled",
              metadataKeyCount: ((.metadata // {}) | keys | length),
              freeformTagCount: ((."freeform-tags" // {}) | keys | length),
              definedTagNamespaceCount: ((."defined-tags" // {}) | keys | length),
              timeCreated: ."time-created"
            }
          ' >> report/compute/compute_instances.jsonl
    done < "$region_target_file"
    progress_newline
  done

  jq -s '.' report/compute/compute_instances.jsonl > report/compute/compute_instances.json
  verbose "wrote 'report/compute/compute_instances.json'"

  jq -r '
    ["compartment-path","region","instance-name","shape","ocpus","memory-in-gbs","baseline-ocpu-utilization","lifecycle-state","availability-domain","fault-domain","image-id","launch-mode","source-type","capacity-reservation-id","dedicated-vm-host-id","preemptible-action-type","availability-recovery-action","legacy-imds-endpoints-disabled","network-type","consistent-volume-naming-enabled","monitoring-disabled","management-disabled","live-migration-preferred","pv-encryption-in-transit-enabled","metadata-key-count","freeform-tag-count","defined-tag-namespace-count","time-created","instance-id"],
    (.[] | [.compartmentPath, .region, .instanceName, .shape, .ocpus, .memoryInGBs, .baselineOcpuUtilization, .lifecycleState, .availabilityDomain, .faultDomain, .imageId, .launchMode, .sourceType, .capacityReservationId, .dedicatedVmHostId, .preemptibleActionType, .availabilityRecoveryAction, .legacyImdsEndpointsDisabled, .networkType, .consistentVolumeNamingEnabled, .monitoringDisabled, .managementDisabled, .liveMigrationPreferred, .pvEncryptionInTransitEnabled, .metadataKeyCount, .freeformTagCount, .definedTagNamespaceCount, .timeCreated, .instanceId]) | @csv
  ' report/compute/compute_instances.json > report/compute/compute_instances.csv
  verbose "wrote 'report/compute/compute_instances.csv'"

  jq -r '
    ["shape","count"],
    (group_by(.shape) | map([.[0].shape, (length|tostring)]) | sort_by(.[1] | tonumber) | reverse | .[]) | @csv
  ' report/compute/compute_instances.json > report/compute/compute_shapes_summary.csv
  verbose "wrote 'report/compute/compute_shapes_summary.csv'"
}

ensure_compute_inventory() {
  [[ -s report/compute/compute_instances.json ]] || build_compute
}

ensure_storage_inventory() {
  [[ -s report/storage/storage_inventory_enriched.json ]] || build_storage
}

ensure_target_regions() {
  [[ -s report/regions.txt ]] || build_regions
}

script_path() {
  local dir
  dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  printf '%s/%s\n' "$dir" "$(basename "${BASH_SOURCE[0]}")"
}

get_compartment_parallelism() {
  local n="${OCI_REVIEW_COMPARTMENT_PARALLELISM:-1}"
  [[ "$n" =~ ^[0-9]+$ ]] || fatal "OCI_REVIEW_COMPARTMENT_PARALLELISM must be a positive integer"
  (( n >= 1 )) || fatal "OCI_REVIEW_COMPARTMENT_PARALLELISM must be >= 1"
  printf '%s\n' "$n"
}

build_compute_compartment_region() {
  local region="$1"
  local cid="$2"
  local out_file="$3"
  local cpath
  cpath="$(get_compartment_path "$cid")"
  oci_cli compute instance list --compartment-id "$cid" --all --region "$region" --output json \
    | jq -c --arg cid "$cid" --arg cpath "$cpath" '
        .data[]? | {
          compartmentId: $cid,
          compartmentPath: $cpath,
          region: .region,
          instanceId: .id,
          instanceName: ."display-name",
          shape: .shape,
          ocpus: ."shape-config".ocpus,
          memoryInGBs: ."shape-config"."memory-in-gbs",
          baselineOcpuUtilization: ."shape-config"."baseline-ocpu-utilization",
          lifecycleState: ."lifecycle-state",
          availabilityDomain: ."availability-domain",
          faultDomain: ."fault-domain",
          imageId: ."image-id",
          launchMode: ."launch-mode",
          sourceType: ."source-details"."source-type",
          capacityReservationId: ."capacity-reservation-id",
          dedicatedVmHostId: ."dedicated-vm-host-id",
          preemptibleActionType: ."preemptible-instance-config"."preemption-action"."type",
          availabilityRecoveryAction: ."availability-config"."recovery-action",
          legacyImdsEndpointsDisabled: ."instance-options"."are-legacy-imds-endpoints-disabled",
          networkType: ."launch-options"."network-type",
          consistentVolumeNamingEnabled: ."launch-options"."is-consistent-volume-naming-enabled",
          monitoringDisabled: ."agent-config"."is-monitoring-disabled",
