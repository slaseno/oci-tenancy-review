  oci_cli bv volume list --compartment-id "$cid" --all --region "$region" --output json \
    | jq -c --arg region "$region" --arg cid "$cid" --rawfile cpath "$cpath_file" '
        .data[]? | {
          kind: "block-volume",
          region: $region,
          compartmentId: $cid,
          compartmentPath: $cpath,
          id: .id,
          displayName: ."display-name",
          lifecycleState: ."lifecycle-state",
          availabilityDomain: ."availability-domain",
          sizeInGBs: ."size-in-gbs",
          vpusPerGB: ."vpus-per-gb",
          isHydrated: ."is-hydrated",
          autoTuneEnabled: ."is-auto-tune-enabled",
          autoTunedVpusPerGB: ."auto-tuned-vpus-per-gb",
          autotunePolicyCount: ((."autotune-policies" // []) | length),
          volumeGroupId: ."volume-group-id",
          replicaAdList: ((."block-volume-replicas" // []) | map(."availability-domain") | map(select(. != null and . != "")) | join("|")),
          imageId: null,
          kmsKeyId: ."kms-key-id",
          backupPolicyId: ."backup-policy-id",
          freeformTagCount: ((."freeform-tags" // {}) | keys | length),
          definedTagNamespaceCount: ((."defined-tags" // {}) | keys | length),
          timeCreated: ."time-created"
        }
      ' > "${out_prefix}.inventory.jsonl"

  oci_cli bv boot-volume list --compartment-id "$cid" --all --region "$region" --output json \
    | jq -c --arg region "$region" --arg cid "$cid" --rawfile cpath "$cpath_file" '
        .data[]? | {
          kind: "boot-volume",
          region: $region,
          compartmentId: $cid,
          compartmentPath: $cpath,
          id: .id,
          displayName: ."display-name",
          lifecycleState: ."lifecycle-state",
          availabilityDomain: ."availability-domain",
          sizeInGBs: ."size-in-gbs",
          vpusPerGB: null,
          isHydrated: ."is-hydrated",
          autoTuneEnabled: null,
          autoTunedVpusPerGB: ."auto-tuned-vpus-per-gb",
          autotunePolicyCount: ((."autotune-policies" // []) | length),
          volumeGroupId: ."volume-group-id",
          replicaAdList: ((."boot-volume-replicas" // []) | map(."availability-domain") | map(select(. != null and . != "")) | join("|")),
          imageId: ."image-id",
          kmsKeyId: ."kms-key-id",
          backupPolicyId: ."backup-policy-id",
          freeformTagCount: ((."freeform-tags" // {}) | keys | length),
          definedTagNamespaceCount: ((."defined-tags" // {}) | keys | length),
          timeCreated: ."time-created"
        }
      ' >> "${out_prefix}.inventory.jsonl"

  oci_cli bv backup list --compartment-id "$cid" --all --region "$region" --output json \
    | jq -c '.data[]? | {sourceId: (."volume-id" // ."source-volume-id" // ""), timeCreated: ."time-created", backupType: (.type // ""), lifecycleState: ."lifecycle-state"} | select(.sourceId != "")' > "${out_prefix}.block_backups.jsonl"
  oci_cli bv boot-volume-backup list --compartment-id "$cid" --all --region "$region" --output json \
    | jq -c '.data[]? | {sourceId: (."boot-volume-id" // ."source-boot-volume-id" // ""), timeCreated: ."time-created", backupType: (.type // ""), lifecycleState: ."lifecycle-state"} | select(.sourceId != "")' > "${out_prefix}.boot_backups.jsonl"
  oci_cli bv block-volume-replica list --compartment-id "$cid" --all --region "$region" --output json \
    | jq -c '.data[]? | {sourceId: (."source-volume-id" // ."volume-id" // ."source-details".id // .sourceDetails.id // ""), lifecycleState: ."lifecycle-state"} | select(.sourceId != "")' > "${out_prefix}.block_replicas.jsonl"
  oci_cli bv boot-volume-replica list --compartment-id "$cid" --all --region "$region" --output json \
    | jq -c '.data[]? | {sourceId: (."source-boot-volume-id" // ."boot-volume-id" // ."source-details".id // .sourceDetails.id // ""), lifecycleState: ."lifecycle-state"} | select(.sourceId != "")' > "${out_prefix}.boot_replicas.jsonl"
  rm -f "$cpath_file"
}

