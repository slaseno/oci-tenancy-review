build_limits_region() {
  local region="$1"
  local out_dir
  local compute_region_json
  local storage_region_json
  local rows_jsonl
  local values_file
  local prefixes_file
  init_report_dirs
  require_tenancy
  [[ -n "$region" ]] || fatal "Region is required"
  out_dir="report/limits/regions/${region}"
  compute_region_json="report/compute/regions/${region}/compute_instances.json"
  storage_region_json="report/storage/regions/${region}/storage_inventory_enriched.json"
  [[ -s "$compute_region_json" ]] || fatal "Missing region compute artifact: $compute_region_json"
  [[ -s "$storage_region_json" ]] || fatal "Missing region storage artifact: $storage_region_json"
  mkdir -p "$out_dir"

  if [[ "$(jq 'length' "$compute_region_json")" -eq 0 ]] && [[ "$(jq 'length' "$storage_region_json")" -eq 0 ]]; then
    echo "[]" > "${out_dir}/service_limits.json"
    jq -n -r '["region","service-name","limit-name","scope-type","availability-domain","limit-value","used","available","usage-percent"] | @csv' > "${out_dir}/service_limits.csv"
    return 0
  fi

  rows_jsonl="${out_dir}/limits_rows.jsonl"
  > "$rows_jsonl"
  local service_name
  for service_name in compute block-storage; do
    values_file="${out_dir}/.values_${region}_${service_name}.json"
    prefixes_file="${out_dir}/.prefixes_${region}.txt"
    if [[ "$service_name" == "compute" ]]; then
      build_region_limit_prefixes "$region" "$prefixes_file" "$compute_region_json"
      [[ -s "$prefixes_file" ]] || continue
    fi
    oci_cli limits value list --compartment-id "$TENANCY_OCID" --service-name "$service_name" --all --region "$region" --output json > "$values_file"
    while IFS=$'\t' read -r limit_name scope_type ad_name limit_value; do
      [[ -n "$limit_name" ]] || continue
      if [[ "$service_name" == "compute" ]] && ! limit_matches_prefixes "$limit_name" "$prefixes_file"; then
        continue
      fi
      local ra_json used_val="" avail_val=""
      if [[ "$scope_type" == "AD" && -n "$ad_name" && "$ad_name" != "null" ]]; then
        if ra_json="$(oci_cli limits resource-availability get --compartment-id "$TENANCY_OCID" --service-name "$service_name" --limit-name "$limit_name" --availability-domain "$ad_name" --region "$region" --output json 2>/dev/null)"; then
          used_val="$(echo "$ra_json" | jq -r '.data.used // .data.currentUsage // empty')"
          avail_val="$(echo "$ra_json" | jq -r '.data.available // .data.availableAmount // empty')"
        fi
      else
        if ra_json="$(oci_cli limits resource-availability get --compartment-id "$TENANCY_OCID" --service-name "$service_name" --limit-name "$limit_name" --region "$region" --output json 2>/dev/null)"; then
          used_val="$(echo "$ra_json" | jq -r '.data.used // .data.currentUsage // empty')"
          avail_val="$(echo "$ra_json" | jq -r '.data.available // .data.availableAmount // empty')"
        fi
      fi
      jq -cn --arg region "$region" --arg service "$service_name" --arg limit "$limit_name" --arg scope "$scope_type" --arg ad "$ad_name" --arg value "$limit_value" --arg used "$used_val" --arg avail "$avail_val" '{region: $region, serviceName: $service, limitName: $limit, scopeType: $scope, availabilityDomain: $ad, limitValue: $value, used: $used, available: $avail}' >> "$rows_jsonl"
    done < <(jq -r '.data[]? | [(.name // ""), (."scope-type" // .scopeType // ""), (."availability-domain" // .availabilityDomain // ""), (.value // "")] | @tsv' "$values_file")
    rm -f "$values_file" "$prefixes_file"
  done

  jq -s 'def to_num: if . == null or . == "" then null else (try (tonumber) catch null) end; def pct($u; $l): if $u == null or $l == null or $l == 0 then null else (($u / $l) * 100) end; map(. as $r | ($r.limitValue | to_num) as $limit | ($r.used | to_num) as $used | ($r.available | to_num) as $avail | (pct($used; $limit)) as $pct | {region: $r.region, serviceName: $r.serviceName, limitName: $r.limitName, scopeType: $r.scopeType, availabilityDomain: $r.availabilityDomain, limitValue: $limit, used: $used, available: $avail, usagePercent: $pct}) | sort_by(-( .usagePercent // -1 ), .region, .serviceName, .limitName)' "$rows_jsonl" > "${out_dir}/service_limits.json"
  jq -r '["region","service-name","limit-name","scope-type","availability-domain","limit-value","used","available","usage-percent"], (.[] | [.region,.serviceName,.limitName,.scopeType,.availabilityDomain,.limitValue,.used,.available,.usagePercent]) | @csv' "${out_dir}/service_limits.json" > "${out_dir}/service_limits.csv"
  verbose "wrote region artifact dir '${out_dir}'"
}

merge_limits_regions() {
  init_report_dirs
  ensure_target_regions
  local -a regions json_files
  local region f
  regions=()
  json_files=()
  while IFS= read -r region; do
    [[ -n "$region" ]] && regions+=("$region")
  done < <(resolve_target_regions)

  for region in "${regions[@]}"; do
    f="report/limits/regions/${region}/service_limits.json"
    [[ -s "$f" ]] || fatal "Missing region limits artifact: $f"
    json_files+=("$f")
  done

  jq -s '
    [.[][]]
    | sort_by(-( .usagePercent // -1 ), .region, .serviceName, .limitName)
  ' "${json_files[@]}" > report/limits/service_limits.json
  verbose "wrote 'report/limits/service_limits.json'"

  jq -r '
    [
      "region",
      "service-name",
      "limit-name",
      "scope-type",
      "availability-domain",
      "limit-value",
      "used",
      "available",
      "usage-percent"
    ],
    (
      .[] |
      [
        .region,
        .serviceName,
        .limitName,
        .scopeType,
        .availabilityDomain,
        .limitValue,
        .used,
        .available,
        .usagePercent
      ]
    ) | @csv
  ' report/limits/service_limits.json > report/limits/service_limits.csv
  verbose "wrote 'report/limits/service_limits.csv'"
}

build_limits() {
  init_report_dirs
  require_tenancy
  ensure_compute_inventory
  ensure_storage_inventory

  local -a regions
  regions=()
  while IFS= read -r region; do
    [[ -n "$region" ]] && regions+=("$region")
  done < <(
    {
      jq -r '.[].region // empty' report/compute/compute_instances.json
      jq -r '.[] | select(.kind=="block-volume") | .region // empty' report/storage/storage_inventory_enriched.json
    } | sort -u
  )

  if [[ "${#regions[@]}" -eq 0 ]]; then
    echo "[]" > report/limits/service_limits.json
    jq -n -r '
      [
        "region",
        "service-name",
        "limit-name",
        "scope-type",
        "availability-domain",
        "limit-value",
        "used",
        "available",
        "usage-percent"
      ] | @csv
    ' > report/limits/service_limits.csv
    verbose "wrote 'report/limits/service_limits.json'"
    verbose "wrote 'report/limits/service_limits.csv'"
    return 0
  fi

  > report/limits/limits_rows.jsonl
  local region
  for region in "${regions[@]}"; do
    local service_name
    for service_name in compute block-storage; do
      local values_file
      values_file="report/limits/.values_${region}_${service_name}.json"
      local prefixes_file
      prefixes_file="report/limits/.prefixes_${region}.txt"

      if [[ "$service_name" == "compute" ]]; then
        build_region_limit_prefixes "$region" "$prefixes_file"
        if [[ ! -s "$prefixes_file" ]]; then
          rm -f "$values_file" "$prefixes_file"
          continue
        fi
      fi

      progress_prefix "build_limits ${region}/${service_name}"
      local had_limit_iterations="false"

      oci_cli limits value list \
        --compartment-id "$TENANCY_OCID" \
        --service-name "$service_name" \
        --all \
        --region "$region" \
        --output json > "$values_file"

      while IFS=$'\t' read -r limit_name scope_type ad_name limit_value; do
        [[ -n "$limit_name" ]] || continue
        if [[ "$service_name" == "compute" ]]; then
          if ! limit_matches_prefixes "$limit_name" "$prefixes_file"; then
            continue
          fi
        fi
        progress_dot
        had_limit_iterations="true"

        local ra_json
        local used_val=""
        local avail_val=""

        if [[ "$scope_type" == "AD" && -n "$ad_name" && "$ad_name" != "null" ]]; then
          if ra_json="$(oci_cli limits resource-availability get \
            --compartment-id "$TENANCY_OCID" \
            --service-name "$service_name" \
            --limit-name "$limit_name" \
            --availability-domain "$ad_name" \
            --region "$region" \
            --output json 2>/dev/null)"; then
            used_val="$(echo "$ra_json" | jq -r '.data.used // .data.currentUsage // empty')"
            avail_val="$(echo "$ra_json" | jq -r '.data.available // .data.availableAmount // empty')"
          fi
        else
          if ra_json="$(oci_cli limits resource-availability get \
            --compartment-id "$TENANCY_OCID" \
            --service-name "$service_name" \
            --limit-name "$limit_name" \
            --region "$region" \
            --output json 2>/dev/null)"; then
            used_val="$(echo "$ra_json" | jq -r '.data.used // .data.currentUsage // empty')"
            avail_val="$(echo "$ra_json" | jq -r '.data.available // .data.availableAmount // empty')"
          fi
        fi

        jq -cn \
          --arg region "$region" \
          --arg service "$service_name" \
          --arg limit "$limit_name" \
          --arg scope "$scope_type" \
          --arg ad "$ad_name" \
          --arg value "$limit_value" \
          --arg used "$used_val" \
          --arg avail "$avail_val" '
          {
            region: $region,
            serviceName: $service,
            limitName: $limit,
            scopeType: $scope,
            availabilityDomain: $ad,
            limitValue: $value,
            used: $used,
            available: $avail
          }
        ' >> report/limits/limits_rows.jsonl
      done < <(
        jq -r '
          .data[]?
          | [
              (.name // ""),
              (."scope-type" // .scopeType // ""),
              (."availability-domain" // .availabilityDomain // ""),
              (.value // "")
            ]
          | @tsv
        ' "$values_file"
      )
      progress_newline
      [[ "$had_limit_iterations" == "true" ]] || true
      rm -f "$values_file" "$prefixes_file"
    done
  done

  jq -s '
    def to_num:
      if . == null or . == "" then null
      else (try (tonumber) catch null) end;
    def pct($u; $l):
      if $u == null or $l == null or $l == 0 then null
      else (($u / $l) * 100) end;
    map(
      . as $r
      | ($r.limitValue | to_num) as $limit
      | ($r.used | to_num) as $used
      | ($r.available | to_num) as $avail
      | (pct($used; $limit)) as $pct
      | {
          region: $r.region,
          serviceName: $r.serviceName,
          limitName: $r.limitName,
          scopeType: $r.scopeType,
          availabilityDomain: $r.availabilityDomain,
          limitValue: $limit,
          used: $used,
          available: $avail,
          usagePercent: $pct
        }
    )
    | sort_by(-( .usagePercent // -1 ), .region, .serviceName, .limitName)
  ' report/limits/limits_rows.jsonl > report/limits/service_limits.json
  verbose "wrote 'report/limits/service_limits.json'"

  jq -r '
    [
      "region",
      "service-name",
      "limit-name",
      "scope-type",
      "availability-domain",
      "limit-value",
      "used",
      "available",
      "usage-percent"
    ],
    (
      .[] |
      [
        .region,
        .serviceName,
        .limitName,
        .scopeType,
        .availabilityDomain,
        .limitValue,
        .used,
        .available,
        .usagePercent
      ]
    ) | @csv
  ' report/limits/service_limits.json > report/limits/service_limits.csv
  verbose "wrote 'report/limits/service_limits.csv'"
}

build_storage() {
  init_report_dirs
  require_tenancy
  ensure_compartments
  ensure_target_regions

  local -a regions
  regions=()
  while IFS= read -r region; do
    [[ -n "$region" ]] && regions+=("$region")
  done < <(resolve_target_regions)

  > report/storage/storage_inventory.jsonl
  > report/storage/block_backups.jsonl
  > report/storage/boot_backups.jsonl
  > report/storage/block_replicas.jsonl
  > report/storage/boot_replicas.jsonl
  echo "region,compartment-id,compartment-path" > report/storage/storage_target_compartments.csv

  local region
  for region in "${regions[@]}"; do
    local volume_targets
    local boot_targets
    local merged_targets
    volume_targets="report/storage/.storage_target_compartments_volume_${region}.csv"
    boot_targets="report/storage/.storage_target_compartments_boot_${region}.csv"
    merged_targets="report/storage/.storage_target_compartments_${region}.csv"

    search "query volume resources" "$volume_targets" "$region"
    search "query bootvolume resources" "$boot_targets" "$region"

    {
      echo "compartment-id,compartment-path"
      {
        tail -n +2 "$volume_targets"
        tail -n +2 "$boot_targets"
      } | sort -u
    } > "$merged_targets"

    while IFS=',' read -r cid cpath; do
      [[ "$cid" == "compartment-id" ]] && continue
      [[ -n "$cid" ]] || continue
      printf '%s,%s,%s\n' "$region" "$cid" "$cpath" >> report/storage/storage_target_compartments.csv
    done < "$merged_targets"

    progress_prefix "build_storage ${region}"
    local had_iterations="false"
    while IFS=',' read -r cid _; do
      [[ "$cid" == "compartment-id" ]] && continue
      [[ -n "$cid" ]] || continue
      progress_dot
      had_iterations="true"

      cpath="$(get_compartment_path "$cid")"

      oci_cli bv volume list --compartment-id "$cid" --all --region "$region" --output json \
        | jq -c --arg region "$region" --arg cid "$cid" --arg cpath "$cpath" '
            .data[]? | {
              kind: "block-volume",
              region: $region,
              compartmentId: $cid,
              compartmentPath: $cpath,
              id: .id,
              displayName: ."display-name",
              lifecycleState: ."lifecycle-state",
              availabilityDomain: ."availability-domain",
              sizeInGBs: ."size-in-gbs",
              vpusPerGB: ."vpus-per-gb",
              autoTuneEnabled: ."is-auto-tune-enabled",
              kmsKeyId: ."kms-key-id",
              backupPolicyId: ."backup-policy-id",
              freeformTagCount: ((."freeform-tags" // {}) | keys | length),
              definedTagNamespaceCount: ((."defined-tags" // {}) | keys | length),
              timeCreated: ."time-created"
            }
          ' >> report/storage/storage_inventory.jsonl

      oci_cli bv boot-volume list --compartment-id "$cid" --all --region "$region" --output json \
        | jq -c --arg region "$region" --arg cid "$cid" --arg cpath "$cpath" '
            .data[]? | {
              kind: "boot-volume",
              region: $region,
              compartmentId: $cid,
              compartmentPath: $cpath,
              id: .id,
              displayName: ."display-name",
              lifecycleState: ."lifecycle-state",
              availabilityDomain: ."availability-domain",
              sizeInGBs: ."size-in-gbs",
              vpusPerGB: null,
              autoTuneEnabled: null,
              kmsKeyId: ."kms-key-id",
              backupPolicyId: ."backup-policy-id",
              freeformTagCount: ((."freeform-tags" // {}) | keys | length),
              definedTagNamespaceCount: ((."defined-tags" // {}) | keys | length),
              timeCreated: ."time-created"
            }
          ' >> report/storage/storage_inventory.jsonl

      oci_cli bv backup list --compartment-id "$cid" --all --region "$region" --output json \
        | jq -c '
            .data[]? | {
              sourceId: (."volume-id" // ."source-volume-id" // ""),
              timeCreated: ."time-created",
              backupType: (.type // ""),
              lifecycleState: ."lifecycle-state"
            } | select(.sourceId != "")
          ' >> report/storage/block_backups.jsonl

      oci_cli bv boot-volume-backup list --compartment-id "$cid" --all --region "$region" --output json \
        | jq -c '
            .data[]? | {
              sourceId: (."boot-volume-id" // ."source-boot-volume-id" // ""),
              timeCreated: ."time-created",
              backupType: (.type // ""),
              lifecycleState: ."lifecycle-state"
            } | select(.sourceId != "")
          ' >> report/storage/boot_backups.jsonl

      oci_cli bv block-volume-replica list --compartment-id "$cid" --all --region "$region" --output json \
        | jq -c '
            .data[]? | {
              sourceId: (."source-volume-id" // ."volume-id" // ."source-details".id // .sourceDetails.id // ""),
              lifecycleState: ."lifecycle-state"
            } | select(.sourceId != "")
          ' >> report/storage/block_replicas.jsonl

      oci_cli bv boot-volume-replica list --compartment-id "$cid" --all --region "$region" --output json \
        | jq -c '
            .data[]? | {
              sourceId: (."source-boot-volume-id" // ."boot-volume-id" // ."source-details".id // .sourceDetails.id // ""),
              lifecycleState: ."lifecycle-state"
            } | select(.sourceId != "")
          ' >> report/storage/boot_replicas.jsonl
    done < "$merged_targets"
    progress_newline
    [[ "$had_iterations" == "true" ]] || true

    rm -f "$volume_targets" "$boot_targets" "$merged_targets"
  done

  {
    echo "region,compartment-id,compartment-path"
    tail -n +2 report/storage/storage_target_compartments.csv | sort -u
  } > report/storage/.storage_target_compartments_sorted.csv
  mv report/storage/.storage_target_compartments_sorted.csv report/storage/storage_target_compartments.csv
  verbose "wrote 'report/storage/storage_target_compartments.csv'"

  jq -s '
    group_by(.sourceId)
    | map({
        (.[0].sourceId): {
          backupCount: length,
          latestBackupTime: (map(.timeCreated) | max),
          latestBackupType: (sort_by(.timeCreated) | last | .backupType)
        }
      })
    | add // {}
  ' report/storage/block_backups.jsonl > report/storage/block_backup_index.json

  jq -s '
    group_by(.sourceId)
    | map({
        (.[0].sourceId): {
          backupCount: length,
          latestBackupTime: (map(.timeCreated) | max),
          latestBackupType: (sort_by(.timeCreated) | last | .backupType)
        }
      })
    | add // {}
  ' report/storage/boot_backups.jsonl > report/storage/boot_backup_index.json

  jq -s '
    group_by(.sourceId)
    | map({ (.[0].sourceId): {replicaCount: length} })
    | add // {}
  ' report/storage/block_replicas.jsonl > report/storage/block_replica_index.json

  jq -s '
    group_by(.sourceId)
    | map({ (.[0].sourceId): {replicaCount: length} })
    | add // {}
  ' report/storage/boot_replicas.jsonl > report/storage/boot_replica_index.json

  jq -s \
    --slurpfile blockBackups report/storage/block_backup_index.json \
    --slurpfile bootBackups report/storage/boot_backup_index.json \
    --slurpfile blockReplicas report/storage/block_replica_index.json \
    --slurpfile bootReplicas report/storage/boot_replica_index.json '
      map(
        . as $v
        | (if $v.kind == "block-volume" then ($blockBackups[0][$v.id] // {}) else ($bootBackups[0][$v.id] // {}) end) as $b
        | (if $v.kind == "block-volume" then ($blockReplicas[0][$v.id] // {}) else ($bootReplicas[0][$v.id] // {}) end) as $r
        | {
            region: $v.region,
            compartmentPath: $v.compartmentPath,
            kind: $v.kind,
            displayName: $v.displayName,
            id: $v.id,
            lifecycleState: $v.lifecycleState,
            availabilityDomain: $v.availabilityDomain,
            sizeInGBs: $v.sizeInGBs,
            vpusPerGB: $v.vpusPerGB,
            autoTuneEnabled: $v.autoTuneEnabled,
            kmsKeyId: $v.kmsKeyId,
            backupPolicyId: $v.backupPolicyId,
            backupCount: ($b.backupCount // 0),
            latestBackupTime: ($b.latestBackupTime // ""),
            latestBackupType: ($b.latestBackupType // ""),
            replicaCount: ($r.replicaCount // 0),
            drProtection: (if (($b.backupCount // 0) > 0 or ($r.replicaCount // 0) > 0 or ($v.backupPolicyId // "") != "") then "YES" else "NO" end),
            freeformTagCount: $v.freeformTagCount,
            definedTagNamespaceCount: $v.definedTagNamespaceCount,
            timeCreated: $v.timeCreated
          }
      )
      | sort_by(.kind, .region, .compartmentPath, .displayName)
    ' report/storage/storage_inventory.jsonl > report/storage/storage_inventory_enriched.json
  verbose "wrote 'report/storage/storage_inventory_enriched.json'"

  jq -r '
    [
      "region",
      "compartment-path",
      "kind",
      "display-name",
      "lifecycle-state",
      "availability-domain",
      "size-in-gbs",
      "vpus-per-gb",
      "auto-tune-enabled",
      "backup-policy-id",
      "backup-count",
      "latest-backup-time",
      "latest-backup-type",
      "replica-count",
      "dr-protection",
      "kms-key-id",
      "freeform-tag-count",
      "defined-tag-namespace-count",
      "time-created",
      "id"
    ],
    (
      .[] |
      [
        .region,
        .compartmentPath,
        .kind,
        .displayName,
        .lifecycleState,
        .availabilityDomain,
        .sizeInGBs,
        .vpusPerGB,
        .autoTuneEnabled,
        .backupPolicyId,
        .backupCount,
        .latestBackupTime,
        .latestBackupType,
        .replicaCount,
        .drProtection,
        .kmsKeyId,
        .freeformTagCount,
        .definedTagNamespaceCount,
        .timeCreated,
        .id
      ]
    ) | @csv
  ' report/storage/storage_inventory_enriched.json > report/storage/storage_inventory.csv
  verbose "wrote 'report/storage/storage_inventory.csv'"
}

main() {
  local cmd=""
  local -a cmd_args
  cmd_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -d|--debug)
        DEBUG_MODE="true"
        ;;
      help|-h|--help)
        if [[ -z "$cmd" ]]; then
          cmd="help"
        else
          fatal "Unknown option: $1"
        fi
        ;;
      *)
        if [[ -z "$cmd" ]]; then
          cmd="$1"
        else
          cmd_args+=("$1")
        fi
        ;;
    esac
    shift
  done

  [[ -n "$cmd" ]] || cmd="help"
  [[ "$DEBUG_MODE" == "true" ]] && set -x

  require_cmd oci
  require_cmd jq
  require_cmd awk
  require_cmd sort

  case "$cmd" in
    _compute-compartment)
      [[ "${#cmd_args[@]}" -eq 3 ]] || fatal "Usage: _compute-compartment <region> <compartment-ocid> <out-file>"
      build_compute_compartment_region "${cmd_args[0]}" "${cmd_args[1]}" "${cmd_args[2]}"
      ;;
    _storage-compartment)
      [[ "${#cmd_args[@]}" -eq 3 ]] || fatal "Usage: _storage-compartment <region> <compartment-ocid> <out-prefix>"
      build_storage_compartment_region "${cmd_args[0]}" "${cmd_args[1]}" "${cmd_args[2]}"
      ;;
    regions)
      build_regions
      ;;
    compute-region)
      [[ "${#cmd_args[@]}" -ge 1 ]] || fatal "Region argument required for compute-region"
      build_compute_region "${cmd_args[0]}"
      ;;
    compute-region-prepare)
      [[ "${#cmd_args[@]}" -ge 1 ]] || fatal "Region argument required for compute-region-prepare"
      prepare_compute_region "${cmd_args[0]}"
      ;;
    compute-region-merge)
      [[ "${#cmd_args[@]}" -ge 1 ]] || fatal "Region argument required for compute-region-merge"
      merge_compute_region "${cmd_args[0]}"
      ;;
    compute-merge)
      merge_compute_regions
      ;;
    compartments)
      build_compartments
      ;;
    policies)
      build_policies
      ;;
    compute)
      build_compute
      ;;
    block-storage-region)
      [[ "${#cmd_args[@]}" -ge 1 ]] || fatal "Region argument required for block-storage-region"
      build_storage_region "${cmd_args[0]}"
      ;;
    block-storage-region-prepare)
      [[ "${#cmd_args[@]}" -ge 1 ]] || fatal "Region argument required for block-storage-region-prepare"
      prepare_storage_region "${cmd_args[0]}"
      ;;
    block-storage-region-merge)
      [[ "${#cmd_args[@]}" -ge 1 ]] || fatal "Region argument required for block-storage-region-merge"
      merge_storage_region "${cmd_args[0]}"
      ;;
    block-storage-merge)
      merge_storage_regions
      ;;
    block-storage)
      build_storage
      ;;
    limits-region)
      [[ "${#cmd_args[@]}" -ge 1 ]] || fatal "Region argument required for limits-region"
      build_limits_region "${cmd_args[0]}"
      ;;
    limits-merge)
      merge_limits_regions
      ;;
    limits)
      build_limits
      ;;
    all)
      build_compartments
      build_compute
      build_storage
      build_limits
      build_policies
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      fatal "Unknown command: $cmd"
      ;;
  esac
}

main "$@"
