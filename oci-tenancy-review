  boot_backups_jsonl="${out_dir}/boot_backups.jsonl"
  block_replicas_jsonl="${out_dir}/block_replicas.jsonl"
  boot_replicas_jsonl="${out_dir}/boot_replicas.jsonl"

  concat_compartment_parts "${out_dir}/compartments" "*.inventory.jsonl" "$inventory_jsonl"
